# Valeris Website - Git Ignore Patterns
# Stack: Astro + Payload CMS + Cloudflare Pages

# ============================================================================
# Operating System Files
# ============================================================================

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Windows
Thumbs.db
[Dd]esktop.ini
$RECYCLE.BIN/

# Linux
*~
.directory
.Trash-*

# ============================================================================
# IDE & Editors
# ============================================================================

# Visual Studio Code
.vscode/
!.vscode/settings.json
!.vscode/extensions.json

# JetBrains
.idea/
*.iml

# Vim/Emacs
[._]*.s[a-v][a-z]
!*.svg
[._]*.sw[a-p]
Session.vim
*~
\#*\#
.\#*

# ============================================================================
# Node.js / JavaScript / TypeScript
# ============================================================================

node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
*.tgz
.npm
.eslintcache
.stylelintcache
*.tsbuildinfo

# ============================================================================
# Astro
# ============================================================================

dist/
.astro/
.output/
.vercel/
.netlify/

# ============================================================================
# Payload CMS
# ============================================================================

# Payload generated types
**/payload-types.ts
**/payload.types.ts

# Payload media uploads (if local)
media/
uploads/

# Payload database (if local SQLite)
*.db
*.sqlite
*.sqlite3

# Payload cache
.payload/

# ============================================================================
# Secrets & Credentials (CRITICAL - NEVER COMMIT)
# ============================================================================

.env
.env.*
!.env.example

*.pem
*.key
secrets/
secrets.json
credentials.json
.secrets/

# ============================================================================
# Build Artifacts
# ============================================================================

build/
out/
*.generated.*

# ============================================================================
# Testing & Coverage
# ============================================================================

coverage/
.nyc_output/
*.lcov
test-results/

# ============================================================================
# Logs & Temporary Files
# ============================================================================

logs/
*.log
tmp/
temp/
*.tmp
*.bak
*.swp

# ============================================================================
# AI Assistants
# ============================================================================

.claude/
.kiro/
.cursor/
.windsurf/

# ============================================================================
# Exceptions (Files to KEEP in Git)
# ============================================================================

!.gitkeep
!.gitattributes
!.prettierrc.md.json
!README.md
!**/README.md
!*.example
!docs-valeris/**/*.md
!docs-valeris/**/*.json

# ============================================================================
# End of .gitignore
# ============================================================================
