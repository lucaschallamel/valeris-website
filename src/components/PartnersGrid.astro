---
// PartnersGrid - Filterable partner cards with logos
// Used by all 4 language versions (FR/DE/EN/IT)

import Section from './ui/Section.astro';
import Row from './ui/Row.astro';
import Col from './ui/Col.astro';
import { partners, categories } from '../data/partners';
import type { Lang } from '../i18n';
import { t } from '../i18n';

// Logo imports (Astro needs static imports for image optimization)
import logoTalan from '../assets/logos/partners/talan.png';
import logoRegdata from '../assets/logos/partners/regdata.jpg';
import logoCloudflare from '../assets/logos/partners/cloudflare.png';
import logoResend from '../assets/logos/partners/resend.jpg';
import logoInfomaniak from '../assets/logos/partners/infomaniak.png';
import logoAzure from '../assets/logos/partners/azure.png';
import logoApple from '../assets/logos/partners/apple.png';
import logoAstro from '../assets/logos/partners/astro.png';
import logoOpencode from '../assets/logos/partners/opencode.png';
import logoAnthropic from '../assets/logos/partners/anthropic.png';
import logoNvidia from '../assets/logos/partners/nvidia.png';
import logoOllama from '../assets/logos/partners/ollama.png';
import logoObsidian from '../assets/logos/partners/obsidian.jpg';
import logoGaicc from '../assets/logos/partners/gaicc.webp';
import logoIapp from '../assets/logos/partners/iapp.png';
import logoIcf from '../assets/logos/partners/icf.jpg';
import logoTogaf from '../assets/logos/partners/togaf.png';
import logoIso from '../assets/logos/partners/iso.png';

const logoMap: Record<string, any> = {
  talan: logoTalan,
  regdata: logoRegdata,
  cloudflare: logoCloudflare,
  resend: logoResend,
  infomaniak: logoInfomaniak,
  azure: logoAzure,
  apple: logoApple,
  astro: logoAstro,
  opencode: logoOpencode,
  anthropic: logoAnthropic,
  nvidia: logoNvidia,
  ollama: logoOllama,
  obsidian: logoObsidian,
  gaicc: logoGaicc,
  iapp: logoIapp,
  icf: logoIcf,
  togaf: logoTogaf,
  iso: logoIso,
};

// Logos that need custom sizing
const logoSizeOverrides: Record<string, string> = {
  obsidian: 'h-11', // 10% bigger than default h-10
  azure: 'h-12',   // icon-only logo, needs to be larger
};

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const i18n = t(lang);

const subtitles: Record<Lang, string> = {
  fr: 'Un écosystème de confiance pour délivrer l\'excellence.',
  de: 'Ein vertrauenswürdiges Ökosystem für exzellente Ergebnisse.',
  en: 'A trusted ecosystem for delivering excellence.',
  it: 'Un ecosistema di fiducia per risultati eccellenti.',
};

const visitLabel: Record<Lang, string> = {
  fr: 'Visiter le site',
  de: 'Website besuchen',
  en: 'Visit website',
  it: 'Visita il sito',
};
---

<Section padding="both" classes="bg-secondary-600">
  <Row>
    <Col span="12" align="center" classes="mb-8">
      <h1 class="mb-4 font-headings text-4xl font-bold text-white">{i18n.nav.partners}</h1>
      <p class="mx-auto max-w-2xl text-lg text-secondary-100">{subtitles[lang]}</p>
    </Col>
  </Row>

  <!-- Category filters -->
  <Row>
    <Col span="12" classes="mb-2">
      <div class="flex flex-wrap items-center justify-center gap-3">
        {Object.entries(categories).map(([key, labels]) => (
          <button
            data-filter={key}
            class:list={[
              'filter-btn rounded-full px-5 py-2 text-sm font-medium transition-colors',
              key === 'all' ? 'is-active' : '',
            ]}
          >
            {labels[lang]}
          </button>
        ))}
      </div>
    </Col>
  </Row>
</Section>

<Section padding="both">
  <div class="partners-grid mx-auto grid max-w-7xl grid-cols-1 gap-6 px-6 md:grid-cols-2 lg:grid-cols-3">
    {partners.map((partner) => {
      const logo = logoMap[partner.logoPath];
      return (
        <a
          href={partner.url}
          target="_blank"
          rel="noopener noreferrer"
          class="partner-card group block overflow-hidden rounded-lg border border-neutral-200 p-6 transition-shadow hover:shadow-lg"
          data-category={partner.category}
        >
          <div class="mb-4 flex h-12 items-center">
            {logo ? (
              <img
                src={logo.src}
                alt={partner.name}
                class:list={[
                  'w-auto max-w-[160px] object-contain grayscale transition-all duration-300 group-hover:grayscale-0',
                  logoSizeOverrides[partner.logoPath] || 'h-10',
                ]}
                loading="lazy"
              />
            ) : (
              <span class="font-headings text-lg font-bold text-neutral-300 transition-colors group-hover:text-secondary-500">{partner.name}</span>
            )}
          </div>
          <h3 class="mb-2 font-headings text-lg font-bold text-neutral-900 group-hover:text-secondary-600">
            {partner.name}
          </h3>
          <p class="mb-4 text-sm text-neutral-500">
            {partner.descriptions[lang]}
          </p>
          <span class="text-sm font-medium text-secondary-500">
            {visitLabel[lang]} &rarr;
          </span>
        </a>
      );
    })}
  </div>
</Section>

<style>
  .filter-btn {
    border: 1px solid rgba(255, 255, 255, 0.3);
    color: rgba(255, 255, 255, 0.8);
    background: transparent;
    cursor: pointer;
  }
  .filter-btn:hover {
    border-color: white;
    color: white;
    background: rgba(255, 255, 255, 0.1);
  }
  .filter-btn.is-active {
    background: white;
    color: var(--color-secondary-700);
    border-color: white;
  }
  .filter-btn.is-active:hover {
    background: var(--color-neutral-50);
    border-color: var(--color-neutral-50);
    color: var(--color-secondary-700);
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
    const cards = document.querySelectorAll<HTMLElement>('.partner-card');

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const filter = btn.dataset.filter;

        buttons.forEach((b) => b.classList.remove('is-active'));
        btn.classList.add('is-active');

        cards.forEach((card) => {
          if (filter === 'all' || card.dataset.category === filter) {
            card.style.display = '';
          } else {
            card.style.display = 'none';
          }
        });
      });
    });
  });
</script>
