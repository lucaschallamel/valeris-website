---
// ContactForm - Trilingual contact form with Resend backend
// Submits to /api/contact (Cloudflare Worker)

import Section from './ui/Section.astro';
import Row from './ui/Row.astro';
import Col from './ui/Col.astro';
import type { Lang } from '../i18n';
import { t } from '../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const i18n = t(lang);
const form = i18n.contact.form;
---

<div class="relative overflow-hidden bg-secondary-600 px-6 py-10 text-center">
  <div class="section__abstract-bg absolute inset-0 bg-cover bg-center opacity-10 pointer-events-none" data-abstract-bg></div>
  <div class="relative z-[1]">
  <h1 class="mb-3 font-headings text-4xl font-bold text-white">{i18n.contact.title}</h1>
  <p class="mx-auto mb-4 max-w-2xl text-lg text-secondary-100">{i18n.contact.expectation}</p>
  <p class="mb-4">
    <a href="tel:+41782223159" class="inline-flex items-center gap-2 font-headings text-2xl font-bold text-white transition-opacity hover:opacity-80">
      <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" /></svg>
      +41 78 222 31 59
    </a>
  </p>
  <div class="flex flex-wrap items-center justify-center gap-4">
    <a href="https://cal.eu/valeris/30min-meet-and-greet" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 rounded-full border border-white px-5 py-2 font-bold text-white transition-opacity hover:opacity-80">
      <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" /></svg>
      {i18n.cta.primary}
    </a>
    <a href="https://www.linkedin.com/in/lucaschallamel/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 rounded-full border border-white px-5 py-2 font-bold text-white transition-opacity hover:opacity-80">
      <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
      LinkedIn
    </a>
  </div>
  </div>
</div>

<Section padding="both" classes="bg-white">
  <Row>
    <Col span="2" />
    <Col span="8">
      <!-- Success / Error messages -->
      <div id="form-success" class="mb-6 hidden rounded-lg bg-green-50 p-4 text-green-800">
        {form.success}
      </div>
      <div id="form-error" class="mb-6 hidden rounded-lg bg-red-50 p-4 text-red-800">
        {form.error}
      </div>

      <form id="contact-form" class="space-y-6" data-submit-label={form.submit} novalidate>
        <input type="hidden" name="lang" value={lang} />

        <!-- Service interest -->
        <div>
          <label for="service" class="mb-2 block text-sm font-bold text-neutral-700">
            {form.serviceInterest}
          </label>
          <select
            id="service"
            name="service"
            class="w-full rounded-lg border border-neutral-200 bg-white px-4 py-3 text-neutral-700 outline-none transition-colors focus:border-primary-500"
          >
            <option value="">{form.selectService}</option>
            <option value="ai-governance">{i18n.services.aiGovernance.name}</option>
            <option value="team-performance">{i18n.services.teamPerformance.name}</option>
            <option value="executive-coaching">{i18n.services.executiveCoaching.name}</option>
            <option value="whitepaper-ai-sovereignty">{form.whitepaper}</option>
            <option value="no-preference">{form.noPreference}</option>
          </select>
        </div>

        <!-- Name row -->
        <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
          <div>
            <label for="firstName" class="mb-2 block text-sm font-bold text-neutral-700">
              {form.firstName} <span class="text-primary-500">*</span>
            </label>
            <input
              type="text"
              id="firstName"
              name="firstName"
              required
              class="w-full rounded-lg border border-neutral-200 px-4 py-3 text-neutral-700 outline-none transition-colors focus:border-primary-500"
            />
          </div>
          <div>
            <label for="lastName" class="mb-2 block text-sm font-bold text-neutral-700">
              {form.lastName} <span class="text-primary-500">*</span>
            </label>
            <input
              type="text"
              id="lastName"
              name="lastName"
              required
              class="w-full rounded-lg border border-neutral-200 px-4 py-3 text-neutral-700 outline-none transition-colors focus:border-primary-500"
            />
          </div>
        </div>

        <!-- Email and Phone -->
        <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
          <div>
            <label for="email" class="mb-2 block text-sm font-bold text-neutral-700">
              {form.email} <span class="text-primary-500">*</span>
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full rounded-lg border border-neutral-200 px-4 py-3 text-neutral-700 outline-none transition-colors focus:border-primary-500"
            />
          </div>
          <div>
            <label for="phone" class="mb-2 block text-sm font-bold text-neutral-700">
              {form.phone}
            </label>
            <input
              type="tel"
              id="phone"
              name="phone"
              class="w-full rounded-lg border border-neutral-200 px-4 py-3 text-neutral-700 outline-none transition-colors focus:border-primary-500"
            />
          </div>
        </div>

        <!-- Company and Job title -->
        <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
          <div>
            <label for="company" class="mb-2 block text-sm font-bold text-neutral-700">
              {form.company}
            </label>
            <input
              type="text"
              id="company"
              name="company"
              class="w-full rounded-lg border border-neutral-200 px-4 py-3 text-neutral-700 outline-none transition-colors focus:border-primary-500"
            />
          </div>
          <div>
            <label for="jobTitle" class="mb-2 block text-sm font-bold text-neutral-700">
              {form.jobTitle}
            </label>
            <input
              type="text"
              id="jobTitle"
              name="jobTitle"
              class="w-full rounded-lg border border-neutral-200 px-4 py-3 text-neutral-700 outline-none transition-colors focus:border-primary-500"
            />
          </div>
        </div>

        <!-- Organisation size -->
        <div>
          <label for="orgSize" class="mb-2 block text-sm font-bold text-neutral-700">
            {form.orgSize}
          </label>
          <select
            id="orgSize"
            name="orgSize"
            class="w-full rounded-lg border border-neutral-200 bg-white px-4 py-3 text-neutral-700 outline-none transition-colors focus:border-primary-500"
          >
            <option value="">-</option>
            <option value="1-49">{form.orgSizes['1-49']}</option>
            <option value="50-199">{form.orgSizes['50-199']}</option>
            <option value="200-999">{form.orgSizes['200-999']}</option>
            <option value="1000+">{form.orgSizes['1000+']}</option>
          </select>
        </div>

        <!-- Message -->
        <div>
          <label for="message" class="mb-2 block text-sm font-bold text-neutral-700">
            {form.message}
          </label>
          <textarea
            id="message"
            name="message"
            rows="4"
            class="w-full resize-y rounded-lg border border-neutral-200 px-4 py-3 text-neutral-700 outline-none transition-colors focus:border-primary-500"
          ></textarea>
        </div>

        <!-- Cloudflare Turnstile -->
        <div class="cf-turnstile" data-sitekey="0x4AAAAAACw1vy6U50c8ODeg" data-theme="light"></div>

        <!-- Honeypot (anti-spam, hidden from humans) -->
        <div class="hidden" aria-hidden="true">
          <input type="text" name="website" tabindex="-1" autocomplete="off" />
        </div>

        <!-- Submit -->
        <div class="flex items-center justify-between">
          <p class="text-sm text-neutral-400">
            <span class="text-primary-500">*</span> {form.required}
          </p>
          <button
            type="submit"
            id="submit-btn"
            class="rounded-full bg-primary-500 px-8 py-3 font-bold text-white transition-colors hover:bg-primary-600 disabled:cursor-not-allowed disabled:opacity-50"
          >
            {form.submit}
          </button>
        </div>
      </form>
    </Col>
    <Col span="2" />
  </Row>
</Section>

<!-- Cloudflare Turnstile script -->
<script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('contact-form') as HTMLFormElement;
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
    const successEl = document.getElementById('form-success')!;
    const errorEl = document.getElementById('form-error')!;
    const submitLabel = form.dataset.submitLabel || 'Send';

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      // Reset messages
      successEl.classList.add('hidden');
      errorEl.classList.add('hidden');

      // Basic validation
      const firstName = (form.querySelector('#firstName') as HTMLInputElement).value.trim();
      const lastName = (form.querySelector('#lastName') as HTMLInputElement).value.trim();
      const email = (form.querySelector('#email') as HTMLInputElement).value.trim();

      if (!firstName || !lastName || !email) {
        errorEl.classList.remove('hidden');
        return;
      }

      // Honeypot check
      const honeypot = (form.querySelector('[name="website"]') as HTMLInputElement).value;
      if (honeypot) return;

      // Turnstile token check
      const turnstileInput = form.querySelector('[name="cf-turnstile-response"]') as HTMLInputElement;
      if (!turnstileInput || !turnstileInput.value) {
        errorEl.classList.remove('hidden');
        return;
      }

      // Disable button
      submitBtn.disabled = true;
      submitBtn.textContent = '...';

      try {
        const formData = new FormData(form);
        const data = Object.fromEntries(formData.entries());

        const response = await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });

        if (response.ok) {
          successEl.classList.remove('hidden');
          form.reset();
          // Reset Turnstile for next submission
          if ((window as any).turnstile) {
            (window as any).turnstile.reset();
          }
        } else {
          errorEl.classList.remove('hidden');
          // Reset Turnstile so user can retry (token is single-use)
          if ((window as any).turnstile) {
            (window as any).turnstile.reset();
          }
        }
      } catch {
        errorEl.classList.remove('hidden');
        // Reset Turnstile on network error too
        if ((window as any).turnstile) {
          (window as any).turnstile.reset();
        }
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = submitLabel;
      }
    });
  });
</script>
