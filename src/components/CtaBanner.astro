---
// CtaBanner - Reusable CTA banner with phone, booking, contact, LinkedIn
// Used across all pages in all 4 languages

import Section from './ui/Section.astro';
import Row from './ui/Row.astro';
import Col from './ui/Col.astro';
import type { Lang } from '../i18n';
import { t, getLocalePath } from '../i18n';

interface Props {
  lang: Lang;
  title?: string;
  subtitle?: string;
}

const { lang, title, subtitle } = Astro.props;
const i18n = t(lang);

const ctaTitle = title || i18n.cta.primary;
const ctaSubtitle = subtitle || i18n.contact.expectation;
const contactLink = getLocalePath('/contact/', lang);
---

<Section id="cta" padding="both">
  <Row>
    <Col span="1" />
    <Col span="10">
      <div class="rounded-xl bg-secondary-600 px-8 py-12 text-center">
        <h2 class="mb-4 font-headings text-2xl font-bold text-white">{ctaTitle}</h2>
        <p class="mx-auto mb-6 max-w-xl text-secondary-100">{ctaSubtitle}</p>

        <!-- Phone -->
        <p class="mb-6">
          <a href="tel:+41782223159" class="inline-flex items-center gap-2 font-headings text-2xl font-bold text-white transition-opacity hover:opacity-80">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" /></svg>
            +41 78 222 31 59
          </a>
        </p>

        <!-- Actions -->
        <div class="flex flex-wrap items-center justify-center gap-4">
          <!-- Booking -->
          <a href="https://cal.eu/valeris/30min-meet-and-greet" target="_blank" rel="noopener noreferrer"
             class="inline-flex items-center gap-2 rounded-full border border-white px-6 py-3 font-bold text-white transition-opacity hover:opacity-80">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" /></svg>
            {i18n.cta.primary}
          </a>
          <!-- Contact -->
          <a href={contactLink}
             class="inline-flex items-center gap-2 rounded-full border border-white px-6 py-3 font-bold text-white transition-opacity hover:opacity-80">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" /></svg>
            {i18n.nav.contact}
          </a>
          <!-- LinkedIn -->
          <a href="https://www.linkedin.com/in/lucaschallamel/" target="_blank" rel="noopener noreferrer"
             class="inline-flex items-center gap-2 rounded-full border border-white px-6 py-3 font-bold text-white transition-opacity hover:opacity-80">
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            LinkedIn
          </a>
        </div>
      </div>
    </Col>
    <Col span="1" />
  </Row>
</Section>
