---
import '../styles/global.css';
import { t, getLangFromUrl, getLocalePath, languages, type Lang } from '../i18n';
import { Image } from 'astro:assets';
import roseIcon from '../assets/logos/valeris-icon-primary.svg';

interface Props {
  title?: string;
  description?: string;
}

const lang = getLangFromUrl(Astro.url);
const i18n = t(lang);
const { title = i18n.site.title, description = i18n.site.description } = Astro.props;
const currentPath = Astro.url.pathname;

// Build alternate language links for hreflang
const alternateLinks = (Object.keys(languages) as Lang[]).map((l) => ({
  lang: l,
  href: `${Astro.site}${getLocalePath(currentPath, l).slice(1)}`,
}));

// Home link for current language
const homeLink = lang === 'fr' ? '/' : `/${lang}/`;
---

<!doctype html>
<html lang={lang} class="font-sans text-neutral-700 antialiased">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    {alternateLinks.map((alt) => (
      <link rel="alternate" hreflang={alt.lang} href={alt.href} />
    ))}
    <link rel="alternate" hreflang="x-default" href={`${Astro.site}`} />
    <title>{title}</title>
  </head>
  <body class="m-0 flex min-h-dvh flex-col bg-white">
    <header class="sticky top-0 z-20 border-b border-neutral-100 bg-white/90 backdrop-blur-sm">
      <nav class="mx-auto flex h-20 max-w-7xl items-center justify-between gap-6 px-6">
        <!-- Logo -->
        <a href={homeLink} class="flex items-center gap-3">
          <img src={roseIcon.src} alt="" class="h-10 w-auto" />
          <span class="font-headings text-2xl font-extrabold tracking-wide text-neutral-900">valeris</span>
        </a>

        <!-- Navigation -->
        <ul class="hidden items-center gap-8 font-medium md:flex">
          <li>
            <a href={getLocalePath('/services/', lang)}
               class="transition-colors hover:text-primary-500">
              {i18n.nav.services}
            </a>
          </li>
          <li>
            <a href={getLocalePath('/a-propos/', lang)}
               class="transition-colors hover:text-primary-500">
              {i18n.nav.about}
            </a>
          </li>
          <li>
            <a href={getLocalePath('/contact/', lang)}
               class="transition-colors hover:text-primary-500">
              {i18n.nav.contact}
            </a>
          </li>
        </ul>

        <!-- Language switcher -->
        <div class="flex items-center gap-1 text-sm">
          {(Object.keys(languages) as Lang[]).map((l) => (
            <a
              href={getLocalePath(currentPath, l)}
              class:list={[
                'rounded px-2 py-1 transition-colors',
                l === lang
                  ? 'font-bold text-primary-500'
                  : 'text-neutral-400 hover:text-neutral-700'
              ]}
              aria-label={languages[l]}
            >
              {l.toUpperCase()}
            </a>
          ))}
        </div>
      </nav>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="border-t border-neutral-100 bg-neutral-50 py-8 text-center text-sm text-neutral-500">
      <div class="mx-auto max-w-7xl px-6">
        <p class="mb-2">&copy; {new Date().getFullYear()} {i18n.footer.copyright}</p>
        <a href={getLocalePath('/mentions-legales/', lang)}
           class="text-neutral-400 transition-colors hover:text-primary-500">
          {i18n.footer.legal}
        </a>
      </div>
    </footer>
  </body>
</html>
