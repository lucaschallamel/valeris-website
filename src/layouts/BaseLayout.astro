---
import '../styles/global.css';
import { t, getLangFromUrl, getLocalePath, languages, type Lang } from '../i18n';
import { Image } from 'astro:assets';
import roseIcon from '../assets/logos/valeris-icon-primary.svg';

interface Props {
  title?: string;
  description?: string;
}

const lang = getLangFromUrl(Astro.url);
const i18n = t(lang);
const { title = i18n.site.title, description = i18n.site.description } = Astro.props;
const currentPath = Astro.url.pathname;

// Build alternate language links for hreflang
const alternateLinks = (Object.keys(languages) as Lang[]).map((l) => ({
  lang: l,
  href: `${Astro.site}${getLocalePath(currentPath, l).slice(1)}`,
}));

// Home link for current language
const homeLink = lang === 'fr' ? '/' : `/${lang}/`;

// Active section detection - maps DE/EN slugs to FR section keys
const pathWithoutLang = currentPath.replace(/^\/(de|en)/, '') || '/';
const sectionMap: Record<string, string> = {
  '/leistungen/': '/services/',
  '/ueber-mich/': '/a-propos/',
  '/kontakt/': '/contact/',
  '/impressum/': '/mentions-legales/',
  '/publikationen/': '/publications/',
};
const normalisedPath = Object.entries(sectionMap).reduce(
  (path, [from, to]) => path.replace(from, to),
  pathWithoutLang
);
function isActiveSection(section: string): boolean {
  if (section === '/') return normalisedPath === '/';
  return normalisedPath.startsWith(section);
}
---

<!doctype html>
<html lang={lang} class="font-sans text-neutral-700 antialiased">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" sizes="48x48" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    {alternateLinks.map((alt) => (
      <link rel="alternate" hreflang={alt.lang} href={alt.href} />
    ))}
    <link rel="alternate" hreflang="x-default" href={`${Astro.site}`} />
    <title>{title}</title>
  </head>
  <body class="m-0 flex min-h-dvh flex-col bg-white">
    <header class="sticky top-0 z-20 border-b border-neutral-100 bg-white/90 backdrop-blur-sm">
      <nav class="mx-auto flex h-20 max-w-7xl items-center justify-between gap-6 px-6">
        <!-- Logo -->
        <a href={homeLink} class="flex items-center gap-3">
          <img src={roseIcon.src} alt="" class="h-10 w-auto" />
          <span class="font-headings text-2xl font-extrabold tracking-wide text-neutral-900">valeris</span>
        </a>

        <!-- Navigation -->
        <ul class="hidden items-center gap-8 font-medium md:flex">
          <!-- Services dropdown -->
          <li class="services-dropdown relative flex h-full items-center">
            <a href={getLocalePath('/services/', lang)}
               class:list={[
                 'flex items-center gap-1 rounded-full px-4 py-2 transition-colors',
                 isActiveSection('/services/')
                   ? 'bg-primary-500 text-white'
                   : 'hover:text-primary-500'
               ]}>
              {i18n.nav.services}
              <svg class:list={['h-4 w-4 transition-transform', isActiveSection('/services/') ? 'text-white' : '']} viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
              </svg>
            </a>
            <ul class="services-menu absolute left-0 top-full z-30 hidden min-w-64 rounded-lg border border-neutral-100 bg-white p-2 pt-3 shadow-lg shadow-neutral-700/5">
              <li>
                <a href={getLocalePath('/services/gouvernance-ia/', lang)}
                   class="block rounded-md px-4 py-2.5 text-sm transition-colors hover:bg-primary-50 hover:text-primary-500">
                  {i18n.services.aiGovernance.name}
                </a>
              </li>
              <li>
                <a href={getLocalePath('/services/performance-equipes/', lang)}
                   class="block rounded-md px-4 py-2.5 text-sm transition-colors hover:bg-primary-50 hover:text-primary-500">
                  {i18n.services.teamPerformance.name}
                </a>
              </li>
              <li>
                <a href={getLocalePath('/services/coaching-executif/', lang)}
                   class="block rounded-md px-4 py-2.5 text-sm transition-colors hover:bg-primary-50 hover:text-primary-500">
                  {i18n.services.executiveCoaching.name}
                </a>
              </li>
            </ul>
          </li>
          <li>
            <a href={getLocalePath('/blog/', lang)}
               class:list={[
                 'rounded-full px-4 py-2 transition-colors',
                 isActiveSection('/blog/')
                   ? 'bg-primary-500 text-white'
                   : 'hover:text-primary-500'
               ]}>
              {i18n.nav.blog}
            </a>
          </li>
          <li>
            <a href={getLocalePath('/publications/', lang)}
               class:list={[
                 'rounded-full px-4 py-2 transition-colors',
                 isActiveSection('/publications/')
                   ? 'bg-primary-500 text-white'
                   : 'hover:text-primary-500'
               ]}>
              {i18n.nav.publications}
            </a>
          </li>
          <li>
            <a href={getLocalePath('/a-propos/', lang)}
               class:list={[
                 'rounded-full px-4 py-2 transition-colors',
                 isActiveSection('/a-propos/')
                   ? 'bg-primary-500 text-white'
                   : 'hover:text-primary-500'
               ]}>
              {i18n.nav.about}
            </a>
          </li>
          <li>
            <a href={getLocalePath('/contact/', lang)}
               class:list={[
                 'rounded-full px-4 py-2 transition-colors',
                 isActiveSection('/contact/')
                   ? 'bg-primary-500 text-white'
                   : 'hover:text-primary-500'
               ]}>
              {i18n.nav.contact}
            </a>
          </li>
        </ul>

        <!-- Language switcher -->
        <div class="flex items-center gap-1 text-sm">
          {(Object.keys(languages) as Lang[]).map((l) => (
            <a
              href={getLocalePath(currentPath, l)}
              class:list={[
                'rounded px-2 py-1 transition-colors',
                l === lang
                  ? 'font-bold text-primary-500'
                  : 'text-neutral-400 hover:text-neutral-700'
              ]}
              aria-label={languages[l]}
            >
              {l.toUpperCase()}
            </a>
          ))}
        </div>
      </nav>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="border-t border-neutral-100 bg-neutral-50 py-8 text-center text-sm text-neutral-500">
      <div class="mx-auto max-w-7xl px-6">
        <p class="mb-2">&copy; {new Date().getFullYear()} {i18n.footer.copyright}</p>
        <a href={getLocalePath('/mentions-legales/', lang)}
           class="text-neutral-400 transition-colors hover:text-primary-500">
          {i18n.footer.legal}
        </a>
      </div>
    </footer>
  </body>
</html>

<style>
  /* Invisible bridge above the menu to prevent hover gap */
  .services-menu::before {
    content: '';
    position: absolute;
    top: -1rem;
    left: 0;
    right: 0;
    height: 1rem;
  }
  .services-dropdown:hover .services-menu,
  .services-dropdown:focus-within .services-menu {
    display: block;
    animation: dropdown 200ms ease-out forwards;
  }
  .services-dropdown:hover svg {
    transform: rotate(180deg);
  }
  @keyframes dropdown {
    from {
      opacity: 0;
      transform: translateY(-0.5rem);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
