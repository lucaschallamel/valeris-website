---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/ui/Section.astro';
import Row from '../../components/ui/Row.astro';
import Col from '../../components/ui/Col.astro';
import Button from '../../components/ui/Button.astro';
import Feature from '../../components/ui/Feature.astro';
import { Image } from 'astro:assets';
import { t } from '../../i18n';
import wpCover from '../../assets/wp_ai_sovereignty_ch.webp';

const i18n = t('it');
import CtaBanner from '../../components/CtaBanner.astro';
---

<BaseLayout title={`${i18n.nav.publications} - ${i18n.site.title}`} description={i18n.site.descriptions.publications}>

  <!-- Hero -->
  <Section padding="both" classes="bg-neutral-50">
    <Row>
      <Col span="2" />
      <Col span="8" align="center">
        <h1 class="mb-4 font-headings text-4xl font-black tracking-tight text-neutral-900 lg:text-5xl">
          Pubblicazioni
        </h1>
        <p class="mx-auto max-w-2xl text-lg text-neutral-500">
          Libri bianchi, saggi e risorse sulla leadership tecnologica, la governance IA e la trasformazione delle organizzazioni.
        </p>
      </Col>
      <Col span="2" />
    </Row>
  </Section>

  <!-- Featured: AI Sovereignty White Paper -->
  <Section padding="both">
    <Row>
      <Col span="1" />
      <Col span="10">
        <div class="rounded-lg border-2 border-primary-100 bg-primary-50/20 p-8 md:p-12">
          <Row>
            <Col span="7">
              <p class="mb-2 text-xs font-bold uppercase tracking-widest text-secondary-500">Libro bianco</p>
              <h2 class="mb-4 font-headings text-3xl font-bold text-neutral-900">
                Sovranità IA: Guida pratica per le imprese svizzere
              </h2>
              <p class="mb-4 text-neutral-600">
                Come adottare l'intelligenza artificiale senza cedere il controllo dei vostri dati, delle vostre decisioni e del vostro futuro digitale. Una guida pragmatica per i dirigenti che vogliono andare oltre il clamore mediatico.
              </p>
              <p class="mb-6 text-sm text-neutral-500">
                Tematiche: sovranità dei dati, quadro normativo svizzero (nDSG) ed europeo (EU AI Act), valutazione dei fornitori, governance dei modelli, costruzione vs acquisto, ISO 42001.
              </p>
              <div class="flex flex-wrap gap-2 mb-6">
                <span class="rounded-full bg-neutral-100 px-3 py-1 text-xs font-medium text-neutral-600">Governance IA</span>
                <span class="rounded-full bg-neutral-100 px-3 py-1 text-xs font-medium text-neutral-600">Sovranità digitale</span>
                <span class="rounded-full bg-neutral-100 px-3 py-1 text-xs font-medium text-neutral-600">ISO 42001</span>
                <span class="rounded-full bg-neutral-100 px-3 py-1 text-xs font-medium text-neutral-600">nDSG / EU AI Act</span>
              </div>
              <Button type="link" size="lg" style="primary" link="/it/contatto/" elevated>
                Ricevere il libro bianco
              </Button>
              <p class="mt-3 text-xs text-neutral-400">Gratuito. Invio per email dopo la registrazione.</p>
            </Col>
            <Col span="5">
              <Image
                src={wpCover}
                alt="Sovranità IA - Libro Bianco per le imprese svizzere"
                class="rounded-lg shadow-lg"
                width={500}
                quality={90}
              />
            </Col>
          </Row>
        </div>
      </Col>
      <Col span="1" />
    </Row>
  </Section>

  <!-- Upcoming publications -->
  <Section padding="both" classes="bg-neutral-50">
    <Row>
      <Col span="2" />
      <Col span="8">
        <h2 class="mb-8 font-headings text-2xl font-bold text-neutral-900 text-center">In arrivo</h2>
        <div class="grid gap-6 md:grid-cols-2">

          <div class="rounded-lg border border-neutral-200 bg-white p-6">
            <p class="mb-2 text-xs font-bold uppercase tracking-widest text-neutral-400">Saggio</p>
            <h3 class="mb-2 font-headings text-xl font-bold text-neutral-900">
              Il CTO nell'era dell'IA generativa
            </h3>
            <p class="mb-4 text-sm text-neutral-500">
              Come il ruolo del direttore tecnico si trasforma quando l'IA diventa un membro del team. Leadership, architettura delle decisioni e la questione dell'obsolescenza volontaria.
            </p>
            <div class="flex flex-wrap gap-2">
              <span class="rounded-full bg-neutral-100 px-3 py-1 text-xs font-medium text-neutral-600">Leadership tecnica</span>
              <span class="rounded-full bg-neutral-100 px-3 py-1 text-xs font-medium text-neutral-600">IA generativa</span>
            </div>
          </div>

          <div class="rounded-lg border border-neutral-200 bg-white p-6">
            <p class="mb-2 text-xs font-bold uppercase tracking-widest text-neutral-400">Saggio</p>
            <h3 class="mb-2 font-headings text-xl font-bold text-neutral-900">
              Misurare ciò che conta: oltre le metriche DORA
            </h3>
            <p class="mb-4 text-sm text-neutral-500">
              Le metriche di performance engineering sono necessarie ma non sufficienti. Ciò che i numeri non catturano - e come completare il quadro.
            </p>
            <div class="flex flex-wrap gap-2">
              <span class="rounded-full bg-neutral-100 px-3 py-1 text-xs font-medium text-neutral-600">Performance engineering</span>
              <span class="rounded-full bg-neutral-100 px-3 py-1 text-xs font-medium text-neutral-600">Metriche</span>
            </div>
          </div>

        </div>
      </Col>
      <Col span="2" />
    </Row>
  </Section>

  <!-- Newsletter / Blog link -->
  <CtaBanner lang="it" />

</BaseLayout>
