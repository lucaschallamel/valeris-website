---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/ui/Section.astro';
import Row from '../../components/ui/Row.astro';
import Col from '../../components/ui/Col.astro';
import Button from '../../components/ui/Button.astro';
import Feature from '../../components/ui/Feature.astro';
import { t } from '../../i18n';

const i18n = t('en');
---

<BaseLayout title={`${i18n.nav.publications} - ${i18n.site.title}`}>

  <!-- Hero -->
  <Section padding="both" classes="bg-neutral-50">
    <Row>
      <Col span="2" />
      <Col span="8" align="center">
        <h1 class="mb-4 font-headings text-4xl font-black tracking-tight text-neutral-900 lg:text-5xl">
          Publications
        </h1>
        <p class="mx-auto max-w-2xl text-lg text-neutral-500">
          White papers, essays and resources on technology leadership, AI governance and organisational transformation.
        </p>
      </Col>
      <Col span="2" />
    </Row>
  </Section>

  <!-- Featured: AI Sovereignty White Paper -->
  <Section padding="both">
    <Row>
      <Col span="1" />
      <Col span="10">
        <div class="rounded-lg border-2 border-primary-100 bg-primary-50/20 p-8 md:p-12">
          <Row>
            <Col span="7">
              <p class="mb-2 text-xs font-bold uppercase tracking-widest text-secondary-500">White paper</p>
              <h2 class="mb-4 font-headings text-3xl font-bold text-neutral-900">
                AI Sovereignty: Practical Guide for Swiss Enterprises
              </h2>
              <p class="mb-4 text-neutral-600">
                How to adopt artificial intelligence without surrendering control of your data, your decisions and your digital future. A pragmatic guide for leaders who want to go beyond the hype.
              </p>
              <p class="mb-6 text-sm text-neutral-500">
                Topics: data sovereignty, Swiss (nDSG) and European regulatory framework (EU AI Act), vendor evaluation, model governance, build vs buy, ISO 42001.
              </p>
              <div class="flex flex-wrap gap-2 mb-6">
                <span class="rounded-full bg-neutral-100 px-3 py-1 text-xs font-medium text-neutral-600">AI Governance</span>
                <span class="rounded-full bg-neutral-100 px-3 py-1 text-xs font-medium text-neutral-600">Digital Sovereignty</span>
                <span class="rounded-full bg-neutral-100 px-3 py-1 text-xs font-medium text-neutral-600">ISO 42001</span>
                <span class="rounded-full bg-neutral-100 px-3 py-1 text-xs font-medium text-neutral-600">nDSG / EU AI Act</span>
              </div>
              <Button type="link" size="lg" style="primary" link="/en/contact/" elevated>
                Get the white paper
              </Button>
              <p class="mt-3 text-xs text-neutral-400">Free. Sent by email after registration.</p>
            </Col>
            <Col span="5">
              <div class="flex h-full min-h-64 items-center justify-center rounded-lg bg-neutral-100">
                <div class="text-center">
                  <p class="text-4xl mb-2">📄</p>
                  <p class="text-sm text-neutral-400">[White paper cover]</p>
                </div>
              </div>
            </Col>
          </Row>
        </div>
      </Col>
      <Col span="1" />
    </Row>
  </Section>

  <!-- Upcoming publications -->
  <Section padding="both" classes="bg-neutral-50">
    <Row>
      <Col span="2" />
      <Col span="8">
        <h2 class="mb-8 font-headings text-2xl font-bold text-neutral-900 text-center">Coming soon</h2>
        <div class="grid gap-6 md:grid-cols-2">

          <!-- Essay 1 -->
          <div class="rounded-lg border border-neutral-200 bg-white p-6">
            <p class="mb-2 text-xs font-bold uppercase tracking-widest text-neutral-400">Essay</p>
            <h3 class="mb-2 font-headings text-xl font-bold text-neutral-900">
              The CTO in the Age of Generative AI
            </h3>
            <p class="mb-4 text-sm text-neutral-500">
              How the role of the technical director transforms when AI becomes a team member. Leadership, decision architecture, and the question of deliberate obsolescence.
            </p>
            <div class="flex flex-wrap gap-2">
              <span class="rounded-full bg-neutral-100 px-3 py-1 text-xs font-medium text-neutral-600">Technical Leadership</span>
              <span class="rounded-full bg-neutral-100 px-3 py-1 text-xs font-medium text-neutral-600">Generative AI</span>
            </div>
          </div>

          <!-- Essay 2 -->
          <div class="rounded-lg border border-neutral-200 bg-white p-6">
            <p class="mb-2 text-xs font-bold uppercase tracking-widest text-neutral-400">Essay</p>
            <h3 class="mb-2 font-headings text-xl font-bold text-neutral-900">
              Measuring What Matters: Beyond DORA Metrics
            </h3>
            <p class="mb-4 text-sm text-neutral-500">
              Engineering performance metrics are necessary but not sufficient. What the numbers do not capture - and how to complete the picture.
            </p>
            <div class="flex flex-wrap gap-2">
              <span class="rounded-full bg-neutral-100 px-3 py-1 text-xs font-medium text-neutral-600">Performance Engineering</span>
              <span class="rounded-full bg-neutral-100 px-3 py-1 text-xs font-medium text-neutral-600">Metrics</span>
            </div>
          </div>

        </div>
      </Col>
      <Col span="2" />
    </Row>
  </Section>

  <!-- Newsletter / Blog link -->
  <Section padding="both">
    <Row>
      <Col span="1" />
      <Col span="10">
        <div class="rounded-xl bg-secondary-600 px-8 py-12 text-center">
          <h2 class="mb-4 font-headings text-2xl font-bold text-white">Regular reflections</h2>
          <p class="mx-auto mb-6 max-w-xl text-secondary-100">
            I also publish regularly on Substack - articles, analyses and podcast episodes on technology leadership, AI and organisational transformation.
          </p>
          <div class="flex flex-wrap justify-center gap-4">
            <Button type="link" size="lg" style="white" variation="outline" link="/en/blog/">
              Read the blog
            </Button>
            <Button type="link" size="lg" style="white" variation="outline" link="https://thecamelhall.substack.com">
              Substack
            </Button>
          </div>
        </div>
      </Col>
      <Col span="1" />
    </Row>
  </Section>

</BaseLayout>
