---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/ui/Section.astro';
import Row from '../../components/ui/Row.astro';
import Col from '../../components/ui/Col.astro';
import Button from '../../components/ui/Button.astro';
import Feature from '../../components/ui/Feature.astro';
import { t } from '../../i18n';

const i18n = t('en');
---

<BaseLayout title={`${i18n.about.title} - ${i18n.site.title}`}>

  <!-- Hero -->
  <Section padding="both" classes="bg-neutral-50">
    <Row>
      <Col span="2" />
      <Col span="8" align="center">
        <h1 class="mb-4 font-headings text-4xl font-black tracking-tight text-neutral-900 lg:text-5xl">
          Lucas Challamel
        </h1>
        <p class="mx-auto max-w-2xl text-lg text-neutral-500">
          Founder, Valeris Coaching. Technical director, solution architect, executive coach. Based in Geneva.
        </p>
      </Col>
      <Col span="2" />
    </Row>
  </Section>

  <!-- Portrait + Narrative -->
  <Section padding="both">
    <Row>
      <Col span="1" />
      <Col span="5">
        <!-- TODO: Replace with professional photo -->
        <div class="flex h-80 items-center justify-center rounded-lg bg-neutral-100">
          <p class="text-neutral-400">[Professional photo]</p>
        </div>
      </Col>
      <Col span="5">
        <h2 class="mb-4 font-headings text-2xl font-bold text-neutral-900">The journey</h2>
        <div class="space-y-4 text-neutral-600">
          <p>
            Over 15 years in technology leadership, from France to Australia then Switzerland. I have built, led and governed technical teams at every scale - from startup to international consulting firm.
          </p>
          <p>
            As Technical Director at Talan SA, I led digital transformation programmes for Swiss companies across finance, pharma and the public sector. I designed solution architectures, established AI governance frameworks, and coached technical leadership teams.
          </p>
          <p>
            What sets me apart: I have held every role I now advise on. I did not read a book about being a CTO - I lived through the sleepless nights, the impossible decisions and the successful transformations.
          </p>
        </div>
      </Col>
      <Col span="1" />
    </Row>
  </Section>

  <!-- Credentials -->
  <Section padding="both" classes="bg-neutral-50">
    <Row>
      <Col span="2" />
      <Col span="8">
        <h2 class="mb-8 font-headings text-2xl font-bold text-neutral-900 text-center">Expertise and credentials</h2>
        <div class="grid gap-8 md:grid-cols-3">
          <Feature icon="heroicons:building-office" title="Experience" align="center">
            <p class="text-sm text-neutral-500">
              15+ years in technical leadership. Former Technical Director, Talan SA. France, Australia, Switzerland.
            </p>
          </Feature>
          <Feature icon="heroicons:academic-cap" title="Certifications" align="center">
            <p class="text-sm text-neutral-500">
              ISO 42001 (in progress). AI/ML, Cloud, IT Governance expertise. TOGAF (planned).
            </p>
          </Feature>
          <Feature icon="heroicons:globe-europe-africa" title="Context" align="center">
            <p class="text-sm text-neutral-500">
              Based in Geneva. Bilingual French/English. Operating in French-speaking Switzerland and internationally.
            </p>
          </Feature>
        </div>
      </Col>
      <Col span="2" />
    </Row>
  </Section>

  <!-- Methodology -->
  <Section padding="both">
    <Row>
      <Col span="2" />
      <Col span="8">
        <h2 class="mb-6 font-headings text-2xl font-bold text-neutral-900">{i18n.about.methodology}</h2>
        <p class="mb-8 text-neutral-600">
          Every engagement starts with a structured diagnostic. No generic templates. No off-the-shelf frameworks. Solutions designed for your specific context.
        </p>
        <div class="grid gap-8 md:grid-cols-3">
          <div class="text-center">
            <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-secondary-400 text-lg font-bold text-white">1</div>
            <h3 class="mb-2 font-headings text-lg font-bold text-neutral-900">Diagnostic</h3>
            <p class="text-sm text-neutral-500">Understand your situation, your constraints, your objectives. Measure before acting.</p>
          </div>
          <div class="text-center">
            <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-secondary-400 text-lg font-bold text-white">2</div>
            <h3 class="mb-2 font-headings text-lg font-bold text-neutral-900">Framing</h3>
            <p class="text-sm text-neutral-500">Define together the scope, measurable objectives and action plan.</p>
          </div>
          <div class="text-center">
            <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-secondary-400 text-lg font-bold text-white">3</div>
            <h3 class="mb-2 font-headings text-lg font-bold text-neutral-900">Support</h3>
            <p class="text-sm text-neutral-500">Execute, measure, adjust. Capability transfer so you become autonomous.</p>
          </div>
        </div>
      </Col>
      <Col span="2" />
    </Row>
  </Section>

  <!-- Values -->
  <Section padding="both" classes="bg-neutral-50">
    <Row>
      <Col span="2" />
      <Col span="8">
        <h2 class="mb-6 font-headings text-2xl font-bold text-neutral-900">How I work</h2>
        <div class="space-y-6">
          <div class="flex gap-4">
            <div class="shrink-0 text-2xl text-primary-500">&bull;</div>
            <div>
              <h3 class="mb-1 font-headings text-lg font-bold text-neutral-900">Directly with you</h3>
              <p class="text-neutral-500">No juniors, no subcontractors. You work directly with me. The scarcity of the interlocutor is part of the value.</p>
            </div>
          </div>
          <div class="flex gap-4">
            <div class="shrink-0 text-2xl text-primary-500">&bull;</div>
            <div>
              <h3 class="mb-1 font-headings text-lg font-bold text-neutral-900">Radical honesty</h3>
              <p class="text-neutral-500">I say no to engagements where I cannot deliver real value. I prefer a relationship of trust over an additional contract.</p>
            </div>
          </div>
          <div class="flex gap-4">
            <div class="shrink-0 text-2xl text-primary-500">&bull;</div>
            <div>
              <h3 class="mb-1 font-headings text-lg font-bold text-neutral-900">Capability transfer</h3>
              <p class="text-neutral-500">The goal is your autonomy, not your dependency. I work with leaders, not for them.</p>
            </div>
          </div>
        </div>
      </Col>
      <Col span="2" />
    </Row>
  </Section>

  <!-- CTA -->
  <Section padding="both">
    <Row>
      <Col span="1" />
      <Col span="10">
        <div class="rounded-xl bg-secondary-600 px-8 py-12 text-center">
          <h2 class="mb-4 font-headings text-2xl font-bold text-white">Ready to talk?</h2>
          <p class="mx-auto mb-6 max-w-xl text-secondary-100">
            A 30-minute conversation, not a sales pitch.
          </p>
          <div class="flex flex-wrap justify-center gap-4">
            <Button type="link" size="lg" style="white" variation="outline" link="/en/contact/">
              {i18n.cta.primary}
            </Button>
            <Button type="link" size="lg" style="white" variation="outline" link="https://linkedin.com/in/lucaschallamel">
              LinkedIn
            </Button>
          </div>
        </div>
      </Col>
      <Col span="1" />
    </Row>
  </Section>

</BaseLayout>
