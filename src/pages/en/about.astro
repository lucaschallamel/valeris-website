---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/ui/Section.astro';
import Row from '../../components/ui/Row.astro';
import Col from '../../components/ui/Col.astro';
import Button from '../../components/ui/Button.astro';
import Feature from '../../components/ui/Feature.astro';
import { Image } from 'astro:assets';
import { t } from '../../i18n';
import portrait from '../../assets/lucas-challamel.jpg';
import valerisLogo from '../../assets/logos/valeris-icon-primary.svg';
import logoNab from '../../assets/logos/clients/nab.png';
import logoUbank from '../../assets/logos/clients/ubank.jpg';

const i18n = t('en');
import CtaBanner from '../../components/CtaBanner.astro';
---

<BaseLayout title={`${i18n.about.title} - ${i18n.site.title}`} description={i18n.site.descriptions.about} seoType="about">

  <!-- Why Valeris -->
  <Section padding="top" classes="bg-neutral-50">
    <Row>
      <Col span="2" />
      <Col span="8" align="center">
        <h1 class="mb-6 font-headings text-4xl font-black tracking-tight text-neutral-900 lg:text-5xl">
          Why Valeris?
        </h1>
      </Col>
      <Col span="2" />
    </Row>
    <Row>
      <Col span="1" />
      <Col span="3" align="center" classes="flex items-center justify-center">
        <img src={valerisLogo.src} alt="Valeris" class="mx-auto h-40 w-auto lg:h-48" />
      </Col>
      <Col span="7">
        <p class="mb-4 text-lg text-neutral-600">
          <em>Valeris</em> comes from the Latin <strong>valeo</strong>: to be well, to be healthy, to be strong.
        </p>
        <p class="mb-4 text-lg text-neutral-600">
          <em>Valeris</em> is the second person future tense: <strong>you will be strong</strong>, <strong>you will be well</strong>. It is a promise and a conviction: with the right support, the right decisions and the right mindset, everything will be fine.
        </p>
        <p class="text-neutral-500">
          This philosophy guides every engagement: strengthening leaders, teams and organisations so they become durably capable, autonomous and confident.
        </p>
      </Col>
      <Col span="1" />
    </Row>
  </Section>

  <!-- Lucas Challamel -->
  <Section padding="top">
    <Row>
      <Col span="1" />
      <Col span="10">
        <div class="rounded-xl bg-secondary-600 px-8 py-8 text-center">
          <h2 class="mb-2 font-headings text-3xl font-bold text-white">Lucas Challamel</h2>
          <p class="mx-auto max-w-2xl text-lg text-secondary-100">
            Founder, Valeris Coaching. 30 years of technology leadership, from startup to international consulting. Trilingual and tricultural: France, Australia, Switzerland.<br />Based in Geneva.
          </p>
        </div>
      </Col>
      <Col span="1" />
    </Row>
  </Section>

  <!-- Portrait + Narrative -->
  <Section padding="top">
    <Row>
      <Col span="1" />
      <Col span="5">
        <div class="mx-auto max-w-[80%]">
          <Image
            src={portrait}
            alt="Lucas Challamel, technology leadership consultant, Geneva"
            class="rounded-lg object-cover grayscale"
            width={600}
            quality={85}
          />
          <div class="mt-4 text-center">
            <p class="font-headings text-lg font-bold text-neutral-900">Lucas Challamel</p>
            <p class="text-sm text-neutral-500">Founder, Valeris Coaching</p>
            <a href="https://www.linkedin.com/in/lucaschallamel/" target="_blank" rel="noopener noreferrer"
               class="mt-3 inline-flex items-center gap-2 rounded-full border border-secondary-500 px-4 py-1.5 text-sm font-medium text-secondary-500 transition-colors hover:bg-secondary-500 hover:text-white">
              <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              LinkedIn
            </a>
          </div>
        </div>
      </Col>
      <Col span="5">
        <h2 class="mb-4 font-headings text-2xl font-bold text-neutral-900">The journey</h2>
        <div class="space-y-4 text-neutral-600">
          <p>
            30 years in software development, architecture and digital transformation. From Grenoble to Marseille, then Sydney, and now Geneva. I have built, led and governed technical teams at every scale.
          </p>
          <p>
            <strong>General Manager Technology at NAB/UBank</strong> in Sydney, I led 100+ professionals, 12 agile squads, with a budget of AUD 30M+. I launched the first Australian banking chatbot and steered the integration of the real-time payments network (AUD 15M programme). Recognised as <strong>top 1% performer</strong> among 34,000 employees.
          </p>
          <p>
            Back in Europe, <strong>Director of Engineering at Azqore</strong> (Indosuez Wealth Management), then <strong>CTO/CIO Advisory at Union Bancaire Privée</strong>, a leading Geneva private bank. I led two missions: first the modernisation of the data protection and anonymisation platform (non-production and production environments), then the coordination of commercial and accounting data migration as part of the acquisition of Société Générale Switzerland and UK. Most recently, <strong>Technical Director and Head of IT Governance at Talan SA</strong> for Switzerland.
          </p>
          <p>
            Before all that, I co-founded and ran <strong>Infostrates</strong> in Marseille for 11 years - 25 employees, with the full reality of entrepreneurship: P&L, business development, and technical delivery.
          </p>
        </div>
      </Col>
      <Col span="1" />
    </Row>
  </Section>

  <!-- Key numbers -->
  <Section padding="both" classes="bg-neutral-50">
    <Row>
      <Col span="1" />
      <Col span="10">
        <div class="grid gap-8 text-center md:grid-cols-5">
          <div>
            <p class="font-headings text-3xl font-black text-secondary-500">30+</p>
            <p class="text-sm text-neutral-500">years of experience</p>
          </div>
          <div>
            <p class="font-headings text-3xl font-black text-secondary-500">100+</p>
            <p class="text-sm text-neutral-500">professionals led</p>
          </div>
          <div>
            <p class="font-headings text-3xl font-black text-secondary-500">Top 1%</p>
            <p class="text-sm text-neutral-500">performer at NAB (34,000 employees)</p>
          </div>
          <div>
            <p class="font-headings text-3xl font-black text-secondary-500">3 countries</p>
            <p class="text-sm text-neutral-500">France, Australia, Switzerland</p>
          </div>
          <div>
            <p class="font-headings text-3xl font-black text-secondary-500">11 years</p>
            <p class="text-sm text-neutral-500">of entrepreneurship</p>
          </div>
        </div>
      </Col>
      <Col span="1" />
    </Row>
  </Section>

  <!-- Career highlights -->
  <Section padding="both">
    <Row>
      <Col span="2" />
      <Col span="8">
        <h2 class="mb-8 font-headings text-2xl font-bold text-neutral-900">Selected experience</h2>
        <div class="space-y-6">
          <div class="flex gap-6 border-l-2 border-secondary-200 pl-6">
            <div class="shrink-0 text-center">
              <p class="text-sm font-bold text-secondary-500">2025</p>
              <span class="mt-1 inline-block rounded bg-red-50 px-1.5 py-0.5 text-[0.6rem] font-medium text-red-400">CH</span>
            </div>
            <div>
              <h3 class="font-headings text-lg font-bold text-neutral-900">Technical Director & Head of IT Governance</h3>
              <p class="text-sm text-neutral-400">Talan SA, Geneva</p>
              <p class="mt-1 text-neutral-600">Leading the IT Governance practice for Talan Switzerland (60+ consultants). Advising Swiss enterprises on enterprise architecture, AI strategy and technology governance.</p>
            </div>
          </div>
          <div class="flex gap-6 border-l-2 border-secondary-200 pl-6">
            <div class="shrink-0 text-center">
              <p class="text-sm font-bold text-secondary-500">2024</p>
              <span class="mt-1 inline-block rounded bg-red-50 px-1.5 py-0.5 text-[0.6rem] font-medium text-red-400">CH</span>
            </div>
            <div>
              <h3 class="font-headings text-lg font-bold text-neutral-900">CTO/CIO Advisory - Private Bank</h3>
              <p class="text-sm text-neutral-400">Union Bancaire Privée (UBP), Geneva</p>
              <p class="mt-1 text-neutral-600">Two missions: modernisation of the data protection and anonymisation platform (non-production and production), then coordination of commercial and accounting data migration as part of the Société Générale Switzerland and UK acquisition. C-suite interface (CIO, CISO, Chief Architect).</p>
            </div>
          </div>
          <div class="flex gap-6 border-l-2 border-secondary-200 pl-6">
            <div class="shrink-0 text-center">
              <p class="text-sm font-bold text-secondary-500">2022</p>
              <span class="mt-1 inline-block rounded bg-red-50 px-1.5 py-0.5 text-[0.6rem] font-medium text-red-400">CH</span>
            </div>
            <div>
              <h3 class="font-headings text-lg font-bold text-neutral-900">Director of Engineering, APIs</h3>
              <p class="text-sm text-neutral-400">Azqore S.A. (Indosuez Wealth Management), Lausanne</p>
              <p class="mt-1 text-neutral-600">API and microservices strategy for wealth management platform (50+ client banks). Managing 20+ engineers. Legacy modernisation to containerised framework.</p>
            </div>
          </div>
          <div class="flex gap-6 border-l-2 border-secondary-200 pl-6">
            <div class="shrink-0 text-center">
              <p class="text-sm font-bold text-secondary-500">2016</p>
              <span class="mt-1 inline-block rounded bg-blue-50 px-1.5 py-0.5 text-[0.6rem] font-medium text-blue-400">AU</span>
            </div>
            <div>
              <h3 class="font-headings text-lg font-bold text-neutral-900">General Manager Technology</h3>
              <p class="text-sm text-neutral-400">NAB / UBank, Sydney</p>
              <p class="mt-1 text-neutral-600">Leading 100+ professionals, 12 agile squads. Budget AUD 30M+. First Australian banking chatbot (IBM Watson). Real-time payments network integration (AUD 15M programme, 45 people, 18 months). Top 1% performer.</p>
            </div>
          </div>
          <div class="flex gap-6 border-l-2 border-secondary-200 pl-6">
            <div class="shrink-0 text-center">
              <p class="text-sm font-bold text-secondary-500">1997</p>
              <span class="mt-1 inline-block rounded bg-indigo-50 px-1.5 py-0.5 text-[0.6rem] font-medium text-indigo-400">FR</span>
            </div>
            <div>
              <h3 class="font-headings text-lg font-bold text-neutral-900">Founder & Technical Director</h3>
              <p class="text-sm text-neutral-400">Infostrates, Marseille</p>
              <p class="mt-1 text-neutral-600">Co-founder and Managing Director of a technology consultancy (25 employees). 11 years of entrepreneurship: P&L, business development, technical delivery.</p>
            </div>
          </div>
        </div>
      </Col>
      <Col span="2" />
    </Row>
  </Section>

  <!-- Credentials -->
  <Section padding="both" classes="bg-neutral-50">
    <Row>
      <Col span="2" />
      <Col span="8">
        <h2 class="mb-8 font-headings text-2xl font-bold text-neutral-900 text-center">Education and certifications</h2>
        <div class="grid gap-6 md:grid-cols-2">
          <Feature icon="heroicons:academic-cap" title="Artificial Intelligence Programme" type="side-icon" iconStyle="square" align="left">
            <p class="text-sm text-neutral-500">MIT, 2024</p>
          </Feature>
          <Feature icon="heroicons:academic-cap" title="Cambridge CTO Programme" type="side-icon" iconStyle="square" align="left">
            <p class="text-sm text-neutral-500">Cambridge Judge Business School, 2018</p>
          </Feature>
          <Feature icon="heroicons:shield-check" title="AWS Cloud Certified Engineer" type="side-icon" iconStyle="square" align="left">
            <p class="text-sm text-neutral-500">Amazon Web Services, 2017</p>
          </Feature>
          <Feature icon="heroicons:shield-check" title="Certified Scrum Master" type="side-icon" iconStyle="square" align="left">
            <p class="text-sm text-neutral-500">Scrum Alliance, 2014</p>
          </Feature>
          <Feature icon="heroicons:building-library" title="Master in Finance & Economics" type="side-icon" iconStyle="square" align="left">
            <p class="text-sm text-neutral-500">Sciences Po Grenoble, 1993</p>
          </Feature>
          <Feature icon="heroicons:building-library" title="Engineering Degree & MPhil" type="side-icon" iconStyle="square" align="left">
            <p class="text-sm text-neutral-500">ENSE3 Grenoble INP, 1991</p>
          </Feature>
        </div>
      </Col>
      <Col span="2" />
    </Row>
  </Section>

  <!-- References -->
  <Section padding="both">
    <Row>
      <Col span="2" />
      <Col span="8">
        <h2 class="mb-8 font-headings text-2xl font-bold text-neutral-900 text-center">Coaching and transformation missions</h2>
        <div class="space-y-8">

          <!-- NAB/UBank -->
          <div class="rounded-lg border border-neutral-200 p-6">
            <div class="mb-4 flex flex-wrap items-start justify-between gap-2">
              <div>
                <p class="text-xs font-bold uppercase tracking-widest text-secondary-500">Team transformation</p>
                <h3 class="font-headings text-xl font-bold text-neutral-900">NAB / UBank</h3>
                <p class="text-sm text-neutral-400">Sydney, Australia - 5 years - 100+ people</p>
              </div>
              <div class="flex items-center gap-2">
                <img src={logoNab.src} alt="NAB" class="h-8 w-auto grayscale opacity-60" />
                <img src={logoUbank.src} alt="UBank" class="h-6 w-auto grayscale opacity-60" />
              </div>
            </div>
            <p class="mb-4 text-neutral-600">
              General Manager Technology. Vantaset coaching programme (first coached for 9 months, then rolled out to 15 tech leads and 100+ staff). Complete cultural transformation: from silos to collaboration, from 54% to 80%+ engagement.
            </p>
            <div class="mb-4 grid gap-3 text-sm md:grid-cols-4">
              <div class="rounded bg-secondary-50 px-3 py-2 text-center">
                <p class="font-bold text-secondary-600">+45 pts</p>
                <p class="text-xs text-neutral-500">engagement</p>
              </div>
              <div class="rounded bg-secondary-50 px-3 py-2 text-center">
                <p class="font-bold text-secondary-600">x4</p>
                <p class="text-xs text-neutral-500">productivity</p>
              </div>
              <div class="rounded bg-secondary-50 px-3 py-2 text-center">
                <p class="font-bold text-secondary-600">-75%</p>
                <p class="text-xs text-neutral-500">time to market</p>
              </div>
              <div class="rounded bg-secondary-50 px-3 py-2 text-center">
                <p class="font-bold text-secondary-600">-60%</p>
                <p class="text-xs text-neutral-500">turnover</p>
              </div>
            </div>
            <div class="space-y-3">
              <blockquote class="border-l-2 border-secondary-200 pl-4 text-sm italic text-neutral-500">
                "People are far more productive and doing better work; in fact they're telling me they are ahead of demand for the first time."
                <span class="mt-1 block not-italic font-medium text-neutral-600">Rohan Anderson, Learning & Development Manager, UBank</span>
              </blockquote>
              <blockquote class="border-l-2 border-secondary-200 pl-4 text-sm italic text-neutral-500">
                "From a value for money perspective, it's been more than excellent. It has completely ignited our people in a new way of working."
                <span class="mt-1 block not-italic font-medium text-neutral-600">Lee Hatton, CEO, UBank</span>
              </blockquote>
            </div>
          </div>

          <!-- Infostrates -->
          <div class="rounded-lg border border-neutral-200 p-6">
            <div class="mb-4 flex flex-wrap items-start justify-between gap-2">
              <div>
                <p class="text-xs font-bold uppercase tracking-widest text-secondary-500">Technical coaching</p>
                <h3 class="font-headings text-xl font-bold text-neutral-900">Digital agency</h3>
                <p class="text-sm text-neutral-400">PACA region, France - 6 months - 30 people</p>
              </div>
            </div>
            <p class="mb-4 text-neutral-600">
              Senior technical coach. Introduced TDD/BDD, industrialised CI/CD pipelines, reduced technical debt, established code standards. The team became autonomous: tech leads now run code reviews and train new joiners.
            </p>
            <div class="mb-4 grid gap-3 text-sm md:grid-cols-4">
              <div class="rounded bg-secondary-50 px-3 py-2 text-center">
                <p class="font-bold text-secondary-600">5% → 65%</p>
                <p class="text-xs text-neutral-500">test coverage</p>
              </div>
              <div class="rounded bg-secondary-50 px-3 py-2 text-center">
                <p class="font-bold text-secondary-600">-70%</p>
                <p class="text-xs text-neutral-500">prod regressions</p>
              </div>
              <div class="rounded bg-secondary-50 px-3 py-2 text-center">
                <p class="font-bold text-secondary-600">-96%</p>
                <p class="text-xs text-neutral-500">lead time</p>
              </div>
              <div class="rounded bg-secondary-50 px-3 py-2 text-center">
                <p class="font-bold text-secondary-600">-73%</p>
                <p class="text-xs text-neutral-500">technical debt</p>
              </div>
            </div>
            <blockquote class="border-l-2 border-secondary-200 pl-4 text-sm italic text-neutral-500">
              "Lucas transformed our approach to development. In 6 months, we went from a team that suffered bugs to a team that prevents them. That is exactly what we expected: a lasting transfer of skills."
              <span class="mt-1 block not-italic font-medium text-neutral-600">The Managing Director</span>
            </blockquote>
          </div>

          <!-- Process Creative -->
          <div class="rounded-lg border border-neutral-200 p-6">
            <div class="mb-4 flex flex-wrap items-start justify-between gap-2">
              <div>
                <p class="text-xs font-bold uppercase tracking-widest text-secondary-500">AI coaching</p>
                <h3 class="font-headings text-xl font-bold text-neutral-900">E-commerce consultancy</h3>
                <p class="text-sm text-neutral-400">Sydney, Australia - 3 months - 10 people</p>
              </div>
            </div>
            <p class="mb-4 text-neutral-600">
              AI coach. Built an AI roadmap, trained the team in AI-assisted pair programming (Copilot, Claude), introduced context engineering and prompt design, deployed AI agents for automation. The team moved from "players" to strategic AI users.
            </p>
            <div class="mb-4 grid gap-3 text-sm md:grid-cols-4">
              <div class="rounded bg-secondary-50 px-3 py-2 text-center">
                <p class="font-bold text-secondary-600">20% → 95%</p>
                <p class="text-xs text-neutral-500">Copilot adoption</p>
              </div>
              <div class="rounded bg-secondary-50 px-3 py-2 text-center">
                <p class="font-bold text-secondary-600">+30%</p>
                <p class="text-xs text-neutral-500">dev productivity</p>
              </div>
              <div class="rounded bg-secondary-50 px-3 py-2 text-center">
                <p class="font-bold text-secondary-600">-75%</p>
                <p class="text-xs text-neutral-500">documentation time</p>
              </div>
              <div class="rounded bg-secondary-50 px-3 py-2 text-center">
                <p class="font-bold text-secondary-600">-83%</p>
                <p class="text-xs text-neutral-500">project onboarding</p>
              </div>
            </div>
            <blockquote class="border-l-2 border-secondary-200 pl-4 text-sm italic text-neutral-500">
              "The team is autonomous and enthusiastic. They share their discoveries, create their own prompts, and see AI as a multiplier of their talent, not a threat."
              <span class="mt-1 block not-italic font-medium text-neutral-600">The CEO</span>
            </blockquote>
          </div>

        </div>
      </Col>
      <Col span="2" />
    </Row>
  </Section>

  <!-- Methodology -->
  <Section padding="both" classes="bg-neutral-50">
    <Row>
      <Col span="2" />
      <Col span="8">
        <h2 class="mb-6 font-headings text-2xl font-bold text-neutral-900">{i18n.about.methodology}</h2>
        <p class="mb-8 text-neutral-600">
          Every engagement starts with a structured diagnostic. No generic templates. No off-the-shelf frameworks. Solutions designed for your specific context.
        </p>
        <div class="grid gap-8 md:grid-cols-3">
          <div class="text-center">
            <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-secondary-400 text-lg font-bold text-white">1</div>
            <h3 class="mb-2 font-headings text-lg font-bold text-neutral-900">Diagnostic</h3>
            <p class="text-sm text-neutral-500">Understand your situation, your constraints, your objectives. Measure before acting. Interviews, data, observation.</p>
          </div>
          <div class="text-center">
            <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-secondary-400 text-lg font-bold text-white">2</div>
            <h3 class="mb-2 font-headings text-lg font-bold text-neutral-900">Framing</h3>
            <p class="text-sm text-neutral-500">Define together the scope, measurable objectives and action plan. No surprises, no ambiguity.</p>
          </div>
          <div class="text-center">
            <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-secondary-400 text-lg font-bold text-white">3</div>
            <h3 class="mb-2 font-headings text-lg font-bold text-neutral-900">Support</h3>
            <p class="text-sm text-neutral-500">Execute, measure, adjust. Integrated capability transfer so you become autonomous.</p>
          </div>
        </div>
      </Col>
      <Col span="2" />
    </Row>
  </Section>

  <!-- Values -->
  <Section padding="both" classes="bg-neutral-50">
    <Row>
      <Col span="2" />
      <Col span="8">
        <h2 class="mb-6 font-headings text-2xl font-bold text-neutral-900">How I work</h2>
        <div class="space-y-6">
          <div class="flex gap-4">
            <div class="shrink-0 text-2xl text-secondary-500">&bull;</div>
            <div>
              <h3 class="mb-1 font-headings text-lg font-bold text-neutral-900">Directly with you</h3>
              <p class="text-neutral-500">No juniors, no subcontractors. You work directly with me. The scarcity of the interlocutor is part of the value.</p>
            </div>
          </div>
          <div class="flex gap-4">
            <div class="shrink-0 text-2xl text-secondary-500">&bull;</div>
            <div>
              <h3 class="mb-1 font-headings text-lg font-bold text-neutral-900">Radical honesty</h3>
              <p class="text-neutral-500">I say no to engagements where I cannot deliver real value. I prefer a relationship of trust over an additional contract.</p>
            </div>
          </div>
          <div class="flex gap-4">
            <div class="shrink-0 text-2xl text-secondary-500">&bull;</div>
            <div>
              <h3 class="mb-1 font-headings text-lg font-bold text-neutral-900">Capability transfer</h3>
              <p class="text-neutral-500">The goal is your autonomy, not your dependency. I work with leaders, not for them.</p>
            </div>
          </div>
          <div class="flex gap-4">
            <div class="shrink-0 text-2xl text-secondary-500">&bull;</div>
            <div>
              <h3 class="mb-1 font-headings text-lg font-bold text-neutral-900">Trilingual, tricultural, global</h3>
              <p class="text-neutral-500">Native French, bilingual English (15 years in Australia), professional Italian. Three cultures, three ways of thinking. France, Australia, Switzerland: I have built and led teams across three continents, including offshore teams in Ukraine, Vietnam and Malaysia. I translate between business and technology, and between cultures.</p>
            </div>
          </div>
        </div>
      </Col>
      <Col span="2" />
    </Row>
  </Section>

  <!-- CTA -->
  <CtaBanner lang="en" />

</BaseLayout>
