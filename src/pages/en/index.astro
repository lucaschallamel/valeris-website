---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/ui/Section.astro';
import Row from '../../components/ui/Row.astro';
import Col from '../../components/ui/Col.astro';
import Button from '../../components/ui/Button.astro';
import { t } from '../../i18n';

const i18n = t('en');
import CtaBanner from '../../components/CtaBanner.astro';
---

<BaseLayout title={`${i18n.site.title} - ${i18n.hero.headline}`} description={i18n.site.descriptions.home}>
  <!-- Hero -->
  <Section id="hero" padding="both" classes="bg-neutral-50" abstractBg>
    <Row>
      <Col span="2" />
      <Col span="8" align="center">
        <h1 class="mb-4 font-headings text-4xl font-black tracking-tight text-neutral-900 lg:text-6xl">
          {i18n.hero.headline}
        </h1>
        <p class="mx-auto mb-8 max-w-2xl text-lg text-neutral-500">
          I help Swiss enterprises get technology transformation right.<br />Not just the strategy, but the execution.
        </p>
        <div class="flex flex-wrap items-center justify-center gap-4">
          <a href="https://cal.eu/valeris/30min-meet-and-greet" target="_blank" rel="noopener noreferrer"
             class="inline-flex items-center gap-2 rounded-full bg-primary-500 px-6 py-3 font-bold text-white shadow-lg transition-colors hover:bg-primary-700">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" /></svg>
            {i18n.cta.primary}
          </a>
          <a href="/en/contact/"
             class="inline-flex items-center gap-2 rounded-full border border-neutral-300 px-6 py-3 font-bold text-neutral-700 transition-colors hover:border-primary-500 hover:text-primary-500">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" /></svg>
            {i18n.nav.contact}
          </a>
        </div>
      </Col>
      <Col span="2" />
    </Row>
  </Section>

  <!-- Services -->
  <Section id="services" padding="top">
    <Row>
      <Col span="12" align="center" classes="mb-10">
        <h2 class="font-headings text-3xl font-bold text-neutral-900">The services I offer</h2>
      </Col>
    </Row>
    <Row>
      <Col span="4">
        <a href="/en/services/ai-governance/" class="group block h-full rounded-lg border border-neutral-200 p-6 transition-all hover:border-primary-300 hover:shadow-lg">
          <div class="mb-3 flex items-center gap-3">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-secondary-50">
              <svg class="h-5 w-5 text-secondary-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" /></svg>
            </div>
            <h3 class="font-headings text-xl font-bold text-neutral-900 group-hover:text-primary-500">{i18n.services.aiGovernance.name}</h3>
          </div>
          <p class="mb-3 text-neutral-500">{i18n.services.aiGovernance.tagline}</p>
          <p class="mb-4 text-sm text-neutral-400">AI maturity diagnostic, ISO 42001 governance framework, data sovereignty, AI FinOps. For CTOs and CISOs who want to structure AI adoption.</p>
          <span class="text-sm font-medium text-primary-500">{i18n.cta.secondary} &rarr;</span>
        </a>
      </Col>
      <Col span="4">
        <a href="/en/services/team-performance/" class="group block h-full rounded-lg border border-neutral-200 p-6 transition-all hover:border-primary-300 hover:shadow-lg">
          <div class="mb-3 flex items-center gap-3">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-secondary-50">
              <svg class="h-5 w-5 text-secondary-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" /></svg>
            </div>
            <h3 class="font-headings text-xl font-bold text-neutral-900 group-hover:text-primary-500">{i18n.services.teamPerformance.name}</h3>
          </div>
          <p class="mb-3 text-neutral-500">{i18n.services.teamPerformance.tagline}</p>
          <p class="mb-4 text-sm text-neutral-400">Embedded technical coaching, TDD/BDD, CI/CD, code reviews. The Coach-Craft method to transform your team performance in 12 weeks.</p>
          <span class="text-sm font-medium text-primary-500">{i18n.cta.secondary} &rarr;</span>
        </a>
      </Col>
      <Col span="4">
        <a href="/en/services/executive-coaching/" class="group block h-full rounded-lg border border-neutral-200 p-6 transition-all hover:border-primary-300 hover:shadow-lg">
          <div class="mb-3 flex items-center gap-3">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-secondary-50">
              <svg class="h-5 w-5 text-secondary-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5" /></svg>
            </div>
            <h3 class="font-headings text-xl font-bold text-neutral-900 group-hover:text-primary-500">{i18n.services.executiveCoaching.name}</h3>
          </div>
          <p class="mb-3 text-neutral-500">{i18n.services.executiveCoaching.tagline}</p>
          <p class="mb-4 text-sm text-neutral-400">Individual coaching for CTOs and VPs Engineering. First 100 days, board alignment, transition to systems leadership in the age of AI.</p>
          <span class="text-sm font-medium text-primary-500">{i18n.cta.secondary} &rarr;</span>
        </a>
      </Col>
    </Row>
  </Section>
  <CtaBanner lang="en" />

</BaseLayout>
