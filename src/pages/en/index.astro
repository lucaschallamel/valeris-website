---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/ui/Section.astro';
import Row from '../../components/ui/Row.astro';
import Col from '../../components/ui/Col.astro';
import Button from '../../components/ui/Button.astro';
import { t } from '../../i18n';

const i18n = t('en');
---

<BaseLayout title={`${i18n.site.title} - ${i18n.hero.headline}`}>
  <Section id="hero" padding="top" classes="bg-neutral-50">
    <Row>
      <Col span="2" />
      <Col span="8" align="center">
        <h1 class="mb-4 font-headings text-4xl font-black tracking-tight text-neutral-900 lg:text-6xl">
          {i18n.hero.headline}
        </h1>
        <p class="mx-auto mb-8 max-w-2xl text-lg text-neutral-500">
          {i18n.hero.subheadline}
        </p>
        <Button type="link" size="lg" style="primary" link="/en/contact/" elevated>
          {i18n.cta.primary}
        </Button>
      </Col>
      <Col span="2" />
    </Row>
  </Section>

  <Section id="services" padding="both">
    <Row>
      <Col span="12" align="center" classes="mb-12">
        <h2 class="font-headings text-3xl font-bold text-neutral-900">{i18n.nav.services}</h2>
      </Col>
    </Row>
    <Row>
      <Col span="4">
        <div class="rounded-lg border border-neutral-200 p-6 transition-shadow hover:shadow-lg">
          <h3 class="mb-2 font-headings text-xl font-bold text-neutral-900">{i18n.services.aiGovernance.name}</h3>
          <p class="mb-4 text-neutral-500">{i18n.services.aiGovernance.tagline}</p>
          <Button type="link" style="primary" variation="link" link="/en/services/ai-governance/">{i18n.cta.secondary} &rarr;</Button>
        </div>
      </Col>
      <Col span="4">
        <div class="rounded-lg border border-neutral-200 p-6 transition-shadow hover:shadow-lg">
          <h3 class="mb-2 font-headings text-xl font-bold text-neutral-900">{i18n.services.teamPerformance.name}</h3>
          <p class="mb-4 text-neutral-500">{i18n.services.teamPerformance.tagline}</p>
          <Button type="link" style="primary" variation="link" link="/en/services/team-performance/">{i18n.cta.secondary} &rarr;</Button>
        </div>
      </Col>
      <Col span="4">
        <div class="rounded-lg border border-neutral-200 p-6 transition-shadow hover:shadow-lg">
          <h3 class="mb-2 font-headings text-xl font-bold text-neutral-900">{i18n.services.executiveCoaching.name}</h3>
          <p class="mb-4 text-neutral-500">{i18n.services.executiveCoaching.tagline}</p>
          <Button type="link" style="primary" variation="link" link="/en/services/executive-coaching/">{i18n.cta.secondary} &rarr;</Button>
        </div>
      </Col>
    </Row>
  </Section>

  <Section id="cta" padding="both" classes="bg-primary-500">
    <Row>
      <Col span="2" />
      <Col span="8" align="center">
        <h2 class="mb-4 font-headings text-3xl font-bold text-white">{i18n.cta.primary}</h2>
        <p class="mx-auto mb-8 max-w-xl text-primary-100">{i18n.hero.subheadline}</p>
        <Button type="link" size="lg" style="white" variation="outline" link="/en/contact/" elevated>{i18n.cta.primary}</Button>
      </Col>
      <Col span="2" />
    </Row>
  </Section>
</BaseLayout>
