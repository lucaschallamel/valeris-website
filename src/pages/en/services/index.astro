---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Section from '../../../components/ui/Section.astro';
import Row from '../../../components/ui/Row.astro';
import Col from '../../../components/ui/Col.astro';

import Feature from '../../../components/ui/Feature.astro';
import { t } from '../../../i18n';

const i18n = t('en');
import CtaBanner from '../../../components/CtaBanner.astro';
---

<BaseLayout title={`${i18n.nav.services} - ${i18n.site.title}`} description={i18n.site.descriptions.services}>

  <!-- Hero -->
  <Section padding="both" classes="bg-neutral-50">
    <Row>
      <Col span="2" />
      <Col span="8" align="center">
        <h1 class="mb-4 font-headings text-4xl font-black tracking-tight text-neutral-900 lg:text-5xl">
          Three altitudes, one objective.
        </h1>
        <p class="mx-auto max-w-2xl text-lg text-neutral-500">
          Technology transformation rarely fails for lack of strategy. It fails when execution is disconnected from leadership. My three offerings address this problem at every level.
        </p>
      </Col>
      <Col span="2" />
    </Row>
    <!-- Altitude diagram -->
    <Row>
      <Col span="3" />
      <Col span="6" align="center" classes="mt-8">
        <div class="flex flex-col items-center gap-1">
          <div class="flex w-48 items-center justify-center rounded-t-lg bg-secondary-700 px-4 py-3 text-center">
            <div>
              <p class="text-xs font-bold uppercase tracking-widest text-secondary-100">Governance</p>
              <p class="text-sm text-white">The what</p>
            </div>
          </div>
          <div class="flex w-64 items-center justify-center bg-secondary-500 px-4 py-3 text-center">
            <div>
              <p class="text-xs font-bold uppercase tracking-widest text-secondary-100">Execution</p>
              <p class="text-sm text-white">The how</p>
            </div>
          </div>
          <div class="flex w-80 items-center justify-center rounded-b-lg bg-secondary-300 px-4 py-3 text-center">
            <div>
              <p class="text-xs font-bold uppercase tracking-widest text-secondary-800">Leadership</p>
              <p class="text-sm text-secondary-700">The who</p>
            </div>
          </div>
        </div>
      </Col>
      <Col span="3" />
    </Row>
  </Section>

  <!-- Three Pillars -->
  <Section padding="both">
    <Row>
      <Col span="12" align="center" classes="mb-12">
        <p class="text-sm font-bold uppercase tracking-widest text-secondary-500">Governance / Execution / Leadership</p>
      </Col>
    </Row>

    <Row classes="mb-16">
      <Col span="1" />
      <Col span="5">
        <a href="/en/services/ai-governance/" class="group block">
          <p class="mb-2 text-sm font-bold uppercase tracking-widest text-secondary-500">The what</p>
          <h2 class="mb-4 font-headings text-2xl font-bold text-neutral-900 group-hover:text-primary-500">{i18n.services.aiGovernance.name}</h2>
          <p class="mb-4 text-neutral-500">{i18n.services.aiGovernance.tagline}</p>
          <p class="mb-6 text-neutral-600">What should we do with AI? Maturity diagnostic across 7 axes, governance framework aligned with ISO 42001, AI sovereignty strategy, activation sprint with built-in governance.</p>
          <p class="mb-2 text-sm text-neutral-400">From CHF 8,500</p>
          <span class="font-bold text-primary-500">Discover this offering &rarr;</span>
        </a>
      </Col>
      <Col span="5">
        <div class="rounded-lg border border-neutral-100 bg-neutral-50 p-8">
          <Feature icon="heroicons:shield-check" title="Who is it for?" align="left">
            <p class="text-sm text-neutral-500">CTOs, CISOs, compliance officers, SME CEOs looking to structure their AI adoption.</p>
          </Feature>
        </div>
      </Col>
      <Col span="1" />
    </Row>

    <Row classes="mb-16">
      <Col span="1" />
      <Col span="5">
        <div class="rounded-lg border border-neutral-100 bg-neutral-50 p-8">
          <Feature icon="heroicons:users" title="Who is it for?" align="left">
            <p class="text-sm text-neutral-500">CTOs, VPs of Engineering, Heads of IT facing delivery, quality or talent retention challenges.</p>
          </Feature>
        </div>
      </Col>
      <Col span="5">
        <a href="/en/services/team-performance/" class="group block">
          <p class="mb-2 text-sm font-bold uppercase tracking-widest text-secondary-500">The how</p>
          <h2 class="mb-4 font-headings text-2xl font-bold text-neutral-900 group-hover:text-primary-500">{i18n.services.teamPerformance.name}</h2>
          <p class="mb-4 text-neutral-500">{i18n.services.teamPerformance.tagline}</p>
          <p class="mb-6 text-neutral-600">How do we actually deliver? Flash diagnostic, embedded Coach & Craft coaching on real sprints, Specification-Driven Development (SDD), measurable DORA metrics from month 3.</p>
          <p class="mb-2 text-sm text-neutral-400">From CHF 5,500</p>
          <span class="font-bold text-primary-500">Discover this offering &rarr;</span>
        </a>
      </Col>
      <Col span="1" />
    </Row>

    <Row>
      <Col span="1" />
      <Col span="5">
        <a href="/en/services/executive-coaching/" class="group block">
          <p class="mb-2 text-sm font-bold uppercase tracking-widest text-secondary-500">The who</p>
          <h2 class="mb-4 font-headings text-2xl font-bold text-neutral-900 group-hover:text-primary-500">{i18n.services.executiveCoaching.name}</h2>
          <p class="mb-4 text-neutral-500">{i18n.services.executiveCoaching.tagline}</p>
          <p class="mb-6 text-neutral-600">Who holds it all together? Trained in high-performance coaching (Vantaset, 9 months), then coach of 100+ staff. Clarity session, 6-month programme, 100-day accelerator.</p>
          <p class="mb-2 text-sm text-neutral-400">From CHF 1,500</p>
          <span class="font-bold text-primary-500">Discover this offering &rarr;</span>
        </a>
      </Col>
      <Col span="5">
        <div class="rounded-lg border border-neutral-100 bg-neutral-50 p-8">
          <Feature icon="heroicons:academic-cap" title="Who is it for?" align="left">
            <p class="text-sm text-neutral-500">Technical leaders in role or in transition, HR directors looking for a coach for a technical leader, CEOs wanting to align their technical leadership.</p>
          </Feature>
        </div>
      </Col>
      <Col span="1" />
    </Row>
  </Section>

  <!-- Cross-selling -->
  <CtaBanner lang="en" />

</BaseLayout>
