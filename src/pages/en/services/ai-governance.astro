---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Section from '../../../components/ui/Section.astro';
import Row from '../../../components/ui/Row.astro';
import Col from '../../../components/ui/Col.astro';
import Button from '../../../components/ui/Button.astro';
import Feature from '../../../components/ui/Feature.astro';
import List from '../../../components/ui/List.astro';
import { t } from '../../../i18n';

const i18n = t('en');
---

<BaseLayout title={`${i18n.services.aiGovernance.name} - ${i18n.site.title}`}>

  <!-- Hero -->
  <Section padding="both" classes="bg-neutral-50">
    <Row>
      <Col span="2" />
      <Col span="8" align="center">
        <p class="mb-4 text-sm font-bold uppercase tracking-widest text-secondary-500">Governance</p>
        <h1 class="mb-4 font-headings text-4xl font-black tracking-tight text-neutral-900 lg:text-5xl">
          {i18n.services.aiGovernance.name}
        </h1>
        <p class="mx-auto max-w-2xl text-lg text-neutral-500">
          {i18n.services.aiGovernance.tagline}
        </p>
      </Col>
      <Col span="2" />
    </Row>
  </Section>

  <!-- The problem -->
  <Section padding="both">
    <Row>
      <Col span="2" />
      <Col span="8">
        <h2 class="mb-6 font-headings text-2xl font-bold text-neutral-900">The problem you face</h2>
        <div class="space-y-4 text-neutral-600">
          <p>Your board is asking for an AI strategy. Your teams are experimenting without a framework. Regulators are moving faster than your governance.</p>
          <p>You have seen the impressive demos. You have launched one or two POCs. But between experimentation and production deployment, there is a chasm that nobody in the organisation knows how to bridge.</p>
          <p>The risk is not failing to adopt AI. It is adopting it poorly - without governance, without risk assessment, without alignment with your regulatory obligations.</p>
        </div>
      </Col>
      <Col span="2" />
    </Row>
  </Section>

  <!-- The approach -->
  <Section padding="both" classes="bg-neutral-50">
    <Row>
      <Col span="2" />
      <Col span="8">
        <h2 class="mb-6 font-headings text-2xl font-bold text-neutral-900">My approach</h2>
        <p class="mb-8 text-neutral-600">
          I combine deep technical expertise in AI/ML with hands-on experience in corporate governance. My approach is aligned with international standards (ISO 42001, EU AI Act) while remaining pragmatic and adapted to the Swiss context.
        </p>
        <div class="grid gap-8 md:grid-cols-2">
          <Feature icon="heroicons:magnifying-glass" title="Maturity diagnostic" type="side-icon" iconStyle="square" align="left">
            <p class="text-sm text-neutral-500">Gap analysis against ISO 42001, maturity scoring, 90-day action plan.</p>
          </Feature>
          <Feature icon="heroicons:document-text" title="Governance framework" type="side-icon" iconStyle="square" align="left">
            <p class="text-sm text-neutral-500">Policies, RACI, risk methodology, use case evaluation matrix, workshops.</p>
          </Feature>
          <Feature icon="heroicons:shield-check" title="ISO 42001 readiness" type="side-icon" iconStyle="square" align="left">
            <p class="text-sm text-neutral-500">Complete AIMS documentation, internal audit, management review, training.</p>
          </Feature>
          <Feature icon="heroicons:rocket-launch" title="AI activation sprint" type="side-icon" iconStyle="square" align="left">
            <p class="text-sm text-neutral-500">One use case from idea to working pilot, with governance built in from the start.</p>
          </Feature>
        </div>
      </Col>
      <Col span="2" />
    </Row>
  </Section>

  <!-- Packages -->
  <Section padding="both">
    <Row>
      <Col span="2" />
      <Col span="8">
        <h2 class="mb-8 font-headings text-2xl font-bold text-neutral-900">Engagement formats</h2>
        <div class="grid gap-6 md:grid-cols-2">
          <!-- Entry point -->
          <div class="rounded-lg border-2 border-secondary-200 bg-secondary-50/30 p-6">
            <p class="mb-1 text-xs font-bold uppercase tracking-widest text-secondary-500">Entry point</p>
            <h3 class="mb-2 font-headings text-xl font-bold text-neutral-900">AI Diagnostic</h3>
            <p class="mb-4 text-sm text-neutral-500">Gap analysis vs ISO 42001, maturity scoring, 90-day action plan.</p>
            <List type="checklist" listItems={[
              { listItem: "5-6 days" },
              { listItem: "Deliverable: report + roadmap" },
              { listItem: "From CHF 8,500" },
            ]} />
          </div>
          <!-- Full journey -->
          <div class="rounded-lg border border-neutral-200 p-6">
            <p class="mb-1 text-xs font-bold uppercase tracking-widest text-neutral-400">Full journey</p>
            <h3 class="mb-2 font-headings text-xl font-bold text-neutral-900">From curiosity to certification</h3>
            <p class="mb-4 text-sm text-neutral-500">Diagnostic, then framework build + activation sprint in parallel, then ISO 42001 readiness.</p>
            <List type="checklist" listItems={[
              { listItem: "6-9 months" },
              { listItem: "CHF 55,000 - 75,000" },
              { listItem: "Goal: ISO 42001 certification" },
            ]} />
          </div>
        </div>
      </Col>
      <Col span="2" />
    </Row>
  </Section>

  <!-- Who this is for -->
  <Section padding="both" classes="bg-neutral-50">
    <Row>
      <Col span="2" />
      <Col span="8">
        <h2 class="mb-6 font-headings text-2xl font-bold text-neutral-900">Who this is for</h2>
        <div class="grid gap-6 md:grid-cols-2">
          <div>
            <h3 class="mb-2 font-headings text-lg font-bold text-neutral-900">Technical directors (CTO/CIO)</h3>
            <p class="text-sm text-neutral-500">Who need to structure AI adoption beyond POCs and present a credible strategy to the board.</p>
          </div>
          <div>
            <h3 class="mb-2 font-headings text-lg font-bold text-neutral-900">Compliance officers / CISO</h3>
            <p class="text-sm text-neutral-500">Who need to assess AI risks and establish a governance framework before the regulator requires it.</p>
          </div>
          <div>
            <h3 class="mb-2 font-headings text-lg font-bold text-neutral-900">SME CEOs (50-500 employees)</h3>
            <p class="text-sm text-neutral-500">Who see AI transforming their industry and want to act in a structured way rather than reactively.</p>
          </div>
          <div>
            <h3 class="mb-2 font-headings text-lg font-bold text-neutral-900">Innovation leaders</h3>
            <p class="text-sm text-neutral-500">Who need a framework to rigorously evaluate, prioritise and launch AI use cases.</p>
          </div>
        </div>
      </Col>
      <Col span="2" />
    </Row>
  </Section>

  <!-- CTA -->
  <Section padding="both">
    <Row>
      <Col span="1" />
      <Col span="10">
        <div class="rounded-xl bg-secondary-600 px-8 py-12 text-center">
          <h2 class="mb-4 font-headings text-2xl font-bold text-white">{i18n.cta.primary}</h2>
          <p class="mx-auto mb-6 max-w-xl text-secondary-100">
            A 30-minute conversation, not a sales pitch.
          </p>
          <Button type="link" size="lg" style="white" variation="outline" link="/en/contact/">
            {i18n.cta.primary}
          </Button>
        </div>
      </Col>
      <Col span="1" />
    </Row>
  </Section>

</BaseLayout>
