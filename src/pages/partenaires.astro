---
import BaseLayout from '../layouts/BaseLayout.astro';
import PartnersGrid from '../components/PartnersGrid.astro';
import CtaBanner from '../components/CtaBanner.astro';
import { t } from '../i18n';

const i18n = t('fr');
---

<BaseLayout title={`${i18n.nav.partners} - ${i18n.site.title}`} description={i18n.site.descriptions.partners}>
  <PartnersGrid lang="fr" />
  <CtaBanner lang="fr" />
</BaseLayout>
