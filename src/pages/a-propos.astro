---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/ui/Section.astro';
import Row from '../components/ui/Row.astro';
import Col from '../components/ui/Col.astro';
import Button from '../components/ui/Button.astro';
import Feature from '../components/ui/Feature.astro';
import { t } from '../i18n';

const i18n = t('fr');
---

<BaseLayout title={`${i18n.about.title} - ${i18n.site.title}`}>

  <!-- Hero -->
  <Section padding="both" classes="bg-neutral-50">
    <Row>
      <Col span="2" />
      <Col span="8" align="center">
        <h1 class="mb-4 font-headings text-4xl font-black tracking-tight text-neutral-900 lg:text-5xl">
          Lucas Challamel
        </h1>
        <p class="mx-auto max-w-2xl text-lg text-neutral-500">
          Fondateur, Valeris Coaching. Directeur technique, architecte de solutions, coach de dirigeants. Basé à Genève.
        </p>
      </Col>
      <Col span="2" />
    </Row>
  </Section>

  <!-- Portrait + Narrative -->
  <Section padding="both">
    <Row>
      <Col span="1" />
      <Col span="5">
        <!-- TODO: Remplacer par une vraie photo professionnelle -->
        <div class="flex h-80 items-center justify-center rounded-lg bg-neutral-100">
          <p class="text-neutral-400">[Photo professionnelle]</p>
        </div>
      </Col>
      <Col span="5">
        <h2 class="mb-4 font-headings text-2xl font-bold text-neutral-900">Le parcours</h2>
        <div class="space-y-4 text-neutral-600">
          <p>
            <!-- TODO: À étoffer avec le CV et l'expérience réelle -->
            Plus de 15 ans dans le leadership technologique, de la France à l'Australie puis la Suisse. J'ai construit, dirigé et gouverné des équipes techniques à chaque échelle - de la startup au cabinet de conseil international.
          </p>
          <p>
            Directeur technique chez Talan SA, j'ai piloté des programmes de transformation numérique pour des entreprises suisses dans la finance, la pharma et le secteur public. J'ai conçu des architectures de solutions, mis en place des frameworks de gouvernance IA, et coaché des équipes de direction technique.
          </p>
          <p>
            Ce qui me distingue : j'ai fait chacun des rôles pour lesquels je conseille aujourd'hui. Je n'ai pas lu un livre sur le métier de CTO - j'ai vécu les nuits blanches, les décisions impossibles et les transformations réussies.
          </p>
        </div>
      </Col>
      <Col span="1" />
    </Row>
  </Section>

  <!-- Credentials -->
  <Section padding="both" classes="bg-neutral-50">
    <Row>
      <Col span="2" />
      <Col span="8">
        <h2 class="mb-8 font-headings text-2xl font-bold text-neutral-900 text-center">Expertise et références</h2>
        <div class="grid gap-8 md:grid-cols-3">
          <Feature icon="heroicons:building-office" title="Expérience" align="center">
            <p class="text-sm text-neutral-500">
              <!-- TODO: À compléter avec détails du CV -->
              15+ ans en direction technique. Ex-Directeur Technique, Talan SA. France, Australie, Suisse.
            </p>
          </Feature>
          <Feature icon="heroicons:academic-cap" title="Certifications" align="center">
            <p class="text-sm text-neutral-500">
              <!-- TODO: À compléter avec les certifications réelles -->
              ISO 42001 (en cours). Expertise AI/ML, Cloud, Gouvernance IT. TOGAF (prévu).
            </p>
          </Feature>
          <Feature icon="heroicons:globe-europe-africa" title="Contexte" align="center">
            <p class="text-sm text-neutral-500">
              Basé à Genève. Bilingue français/anglais. Opérant en Suisse romande et à l'international.
            </p>
          </Feature>
        </div>
      </Col>
      <Col span="2" />
    </Row>
  </Section>

  <!-- Methodology -->
  <Section padding="both">
    <Row>
      <Col span="2" />
      <Col span="8">
        <h2 class="mb-6 font-headings text-2xl font-bold text-neutral-900">{i18n.about.methodology}</h2>
        <p class="mb-8 text-neutral-600">
          Chaque engagement commence par un diagnostic structuré. Pas de templates génériques. Pas de frameworks pré-fabriqués. Des solutions conçues pour votre contexte spécifique.
        </p>
        <div class="grid gap-8 md:grid-cols-3">
          <div class="text-center">
            <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-secondary-400 text-lg font-bold text-white">1</div>
            <h3 class="mb-2 font-headings text-lg font-bold text-neutral-900">Diagnostic</h3>
            <p class="text-sm text-neutral-500">Comprendre votre situation, vos contraintes, vos objectifs. Mesurer avant d'agir.</p>
          </div>
          <div class="text-center">
            <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-secondary-400 text-lg font-bold text-white">2</div>
            <h3 class="mb-2 font-headings text-lg font-bold text-neutral-900">Cadrage</h3>
            <p class="text-sm text-neutral-500">Définir ensemble le périmètre, les objectifs mesurables et le plan d'action.</p>
          </div>
          <div class="text-center">
            <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-secondary-400 text-lg font-bold text-white">3</div>
            <h3 class="mb-2 font-headings text-lg font-bold text-neutral-900">Accompagnement</h3>
            <p class="text-sm text-neutral-500">Exécuter, mesurer, ajuster. Transfert de compétences pour que vous deveniez autonome.</p>
          </div>
        </div>
      </Col>
      <Col span="2" />
    </Row>
  </Section>

  <!-- Values -->
  <Section padding="both" classes="bg-neutral-50">
    <Row>
      <Col span="2" />
      <Col span="8">
        <h2 class="mb-6 font-headings text-2xl font-bold text-neutral-900">Comment je travaille</h2>
        <div class="space-y-6">
          <div class="flex gap-4">
            <div class="shrink-0 text-2xl text-primary-500">&bull;</div>
            <div>
              <h3 class="mb-1 font-headings text-lg font-bold text-neutral-900">Directement avec vous</h3>
              <p class="text-neutral-500">Pas de juniors, pas de sous-traitants. Vous travaillez directement avec moi. La rareté de l'interlocuteur fait partie de la valeur.</p>
            </div>
          </div>
          <div class="flex gap-4">
            <div class="shrink-0 text-2xl text-primary-500">&bull;</div>
            <div>
              <h3 class="mb-1 font-headings text-lg font-bold text-neutral-900">Honnêteté radicale</h3>
              <p class="text-neutral-500">Je dis non aux engagements où je ne peux pas apporter de vraie valeur. Je préfère une relation de confiance à un contrat supplémentaire.</p>
            </div>
          </div>
          <div class="flex gap-4">
            <div class="shrink-0 text-2xl text-primary-500">&bull;</div>
            <div>
              <h3 class="mb-1 font-headings text-lg font-bold text-neutral-900">Transfert de compétences</h3>
              <p class="text-neutral-500">L'objectif est votre autonomie, pas votre dépendance. Je travaille avec les leaders, pas pour eux.</p>
            </div>
          </div>
        </div>
      </Col>
      <Col span="2" />
    </Row>
  </Section>

  <!-- CTA -->
  <Section padding="both">
    <Row>
      <Col span="1" />
      <Col span="10">
        <div class="rounded-xl bg-secondary-600 px-8 py-12 text-center">
          <h2 class="mb-4 font-headings text-2xl font-bold text-white">Prêt à en discuter ?</h2>
          <p class="mx-auto mb-6 max-w-xl text-secondary-100">
            Un échange de 30 minutes, pas un pitch commercial.
          </p>
          <div class="flex flex-wrap justify-center gap-4">
            <Button type="link" size="lg" style="white" variation="outline" link="/contact/">
              {i18n.cta.primary}
            </Button>
            <Button type="link" size="lg" style="white" variation="outline" link="https://linkedin.com/in/lucaschallamel">
              LinkedIn
            </Button>
          </div>
        </div>
      </Col>
      <Col span="1" />
    </Row>
  </Section>

</BaseLayout>
