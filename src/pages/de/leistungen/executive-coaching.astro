---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Section from '../../../components/ui/Section.astro';
import Row from '../../../components/ui/Row.astro';
import Col from '../../../components/ui/Col.astro';
import Button from '../../../components/ui/Button.astro';
import Feature from '../../../components/ui/Feature.astro';
import List from '../../../components/ui/List.astro';
import { t } from '../../../i18n';

const i18n = t('de');
---

<BaseLayout title={`${i18n.services.executiveCoaching.name} - ${i18n.site.title}`}>

  <!-- Hero -->
  <Section padding="both" classes="bg-neutral-50">
    <Row>
      <Col span="2" />
      <Col span="8" align="center">
        <p class="mb-4 text-sm font-bold uppercase tracking-widest text-secondary-500">Leadership</p>
        <h1 class="mb-4 font-headings text-4xl font-black tracking-tight text-neutral-900 lg:text-5xl">
          {i18n.services.executiveCoaching.name}
        </h1>
        <p class="mx-auto max-w-2xl text-lg text-neutral-500">
          {i18n.services.executiveCoaching.tagline}
        </p>
      </Col>
      <Col span="2" />
    </Row>
  </Section>

  <!-- Das Problem -->
  <Section padding="both">
    <Row>
      <Col span="2" />
      <Col span="8">
        <h2 class="mb-6 font-headings text-2xl font-bold text-neutral-900">Das Problem, das Sie kennen</h2>
        <div class="space-y-4 text-neutral-600">
          <p>Sie sind vom "besten Ingenieur" zur "technischen Führungskraft" aufgestiegen. Die Rolle hat sich verändert, aber niemand hat Ihnen die neue Gebrauchsanweisung gegeben.</p>
          <p>Sie verwalten Budgets, Stakeholder, politische Spannungen. Sie treffen Entscheidungen, die Dutzende oder Hunderte von Menschen betreffen. Und Sie tun dies oft allein, weil es niemand anderen in der Organisation gibt, der Ihre Position wirklich versteht.</p>
          <p>Generalistische Coaches verstehen die Technologie nicht. Technische Berater verstehen das Leadership nicht. Sie brauchen jemanden, der beides gelebt hat.</p>
        </div>
      </Col>
      <Col span="2" />
    </Row>
  </Section>

  <!-- Der Ansatz -->
  <Section padding="both" classes="bg-neutral-50">
    <Row>
      <Col span="2" />
      <Col span="8">
        <h2 class="mb-6 font-headings text-2xl font-bold text-neutral-900">Mein Ansatz</h2>
        <p class="mb-8 text-neutral-600">
          Ich bin kein Coach, der Bücher über Technologie gelesen hat. Ich bin eine technische Führungskraft, die Coaching gelernt hat. Den Unterschied spüren Sie ab der ersten Session.
        </p>
        <div class="grid gap-8 md:grid-cols-2">
          <Feature icon="heroicons:sparkles" title="Clarity Session" type="side-icon" iconStyle="square" align="left">
            <p class="text-sm text-neutral-500">Ein 2-stündiger Deep-Dive zu einer spezifischen Herausforderung. Problemeingrenzung, Optionen, Aktionsplan.</p>
          </Feature>
          <Feature icon="heroicons:calendar-days" title="Coaching-Programm" type="side-icon" iconStyle="square" align="left">
            <p class="text-sm text-neutral-500">6 Monate, zweiwöchentliche Sessions à 90 Min., 360-Assessment, personalisierter Entwicklungsplan.</p>
          </Feature>
          <Feature icon="heroicons:fire" title="100-Tage-Beschleuniger" type="side-icon" iconStyle="square" align="left">
            <p class="text-sm text-neutral-500">Intensives Coaching für eine Führungskraft beim Stellenantritt. Wöchentlich, dann zweiwöchentlich.</p>
          </Feature>
          <Feature icon="heroicons:user-group" title="Team-Alignment" type="side-icon" iconStyle="square" align="left">
            <p class="text-sm text-neutral-500">Gruppen-Coaching für 4-6 technische Leader. 4 Monate, um ein abgestimmtes Führungsteam zu schaffen.</p>
          </Feature>
        </div>
      </Col>
      <Col span="2" />
    </Row>
  </Section>

  <!-- Pakete -->
  <Section padding="both">
    <Row>
      <Col span="2" />
      <Col span="8">
        <h2 class="mb-8 font-headings text-2xl font-bold text-neutral-900">Engagement-Formate</h2>
        <div class="grid gap-6 md:grid-cols-2">
          <div class="rounded-lg border-2 border-secondary-200 bg-secondary-50/30 p-6">
            <p class="mb-1 text-xs font-bold uppercase tracking-widest text-secondary-500">Einstiegspunkt</p>
            <h3 class="mb-2 font-headings text-xl font-bold text-neutral-900">Clarity Session</h3>
            <p class="mb-4 text-sm text-neutral-500">Ein 2-stündiger Deep-Dive. Kein Procurement nötig. Sie gehen mit einem Aktionsplan nach Hause.</p>
            <List type="checklist" listItems={[
              { listItem: "2 Stunden" },
              { listItem: "Lieferobjekt: Zusammenfassung + Aktionsplan" },
              { listItem: "CHF 1 500" },
            ]} />
          </div>
          <div class="rounded-lg border border-neutral-200 p-6">
            <p class="mb-1 text-xs font-bold uppercase tracking-widest text-neutral-400">Vollständiger Weg</p>
            <h3 class="mb-2 font-headings text-xl font-bold text-neutral-900">Leadership-Transformation</h3>
            <p class="mb-4 text-sm text-neutral-500">Clarity Session, dann 6-Monats-Coaching-Programm, potenziell erweitert auf das Führungsteam.</p>
            <List type="checklist" listItems={[
              { listItem: "6-12 Monate" },
              { listItem: "CHF 40 000 - 50 000" },
              { listItem: "360-Assessment + Entwicklungsplan" },
            ]} />
          </div>
        </div>
      </Col>
      <Col span="2" />
    </Row>
  </Section>

  <!-- Für wen -->
  <Section padding="both" classes="bg-neutral-50">
    <Row>
      <Col span="2" />
      <Col span="8">
        <h2 class="mb-6 font-headings text-2xl font-bold text-neutral-900">Für wen</h2>
        <div class="grid gap-6 md:grid-cols-2">
          <div>
            <h3 class="mb-2 font-headings text-lg font-bold text-neutral-900">CTO / VP Engineering im Amt</h3>
            <p class="text-sm text-neutral-500">Die in ihrer Rolle auf die nächste Stufe kommen und ihren strategischen Einfluss ausbauen wollen.</p>
          </div>
          <div>
            <h3 class="mb-2 font-headings text-lg font-bold text-neutral-900">Führungskräfte im Übergang</h3>
            <p class="text-sm text-neutral-500">Neue CTOs, interne Beförderungen, Zuständigkeitswechsel - die ersten 100 Tage sind entscheidend.</p>
          </div>
          <div>
            <h3 class="mb-2 font-headings text-lg font-bold text-neutral-900">HR / Talent</h3>
            <p class="text-sm text-neutral-500">Die einen spezialisierten Coach für eine technische Führungskraft suchen und ein strukturiertes Programm wünschen.</p>
          </div>
          <div>
            <h3 class="mb-2 font-headings text-lg font-bold text-neutral-900">CEO von KMU</h3>
            <p class="text-sm text-neutral-500">Die ihr technisches Führungsteam ausrichten und eine gemeinsame Umsetzungskultur schaffen wollen.</p>
          </div>
        </div>
      </Col>
      <Col span="2" />
    </Row>
  </Section>

  <!-- CTA -->
  <Section padding="both">
    <Row>
      <Col span="1" />
      <Col span="10">
        <div class="rounded-xl bg-secondary-600 px-8 py-12 text-center">
          <h2 class="mb-4 font-headings text-2xl font-bold text-white">{i18n.cta.primary}</h2>
          <p class="mx-auto mb-6 max-w-xl text-secondary-100">
            Ein 30-minütiges Gespräch, kein Verkaufspitch.
          </p>
          <Button type="link" size="lg" style="white" variation="outline" link="/de/kontakt/">
            {i18n.cta.primary}
          </Button>
        </div>
      </Col>
      <Col span="1" />
    </Row>
  </Section>

</BaseLayout>
