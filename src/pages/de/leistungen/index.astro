---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Section from '../../../components/ui/Section.astro';
import Row from '../../../components/ui/Row.astro';
import Col from '../../../components/ui/Col.astro';
import Button from '../../../components/ui/Button.astro';
import Feature from '../../../components/ui/Feature.astro';
import { t } from '../../../i18n';

const i18n = t('de');
---

<BaseLayout title={`${i18n.nav.services} - ${i18n.site.title}`}>

  <!-- Hero -->
  <Section padding="both" classes="bg-neutral-50">
    <Row>
      <Col span="2" />
      <Col span="8" align="center">
        <h1 class="mb-4 font-headings text-4xl font-black tracking-tight text-neutral-900 lg:text-5xl">
          Drei Ebenen, ein Ziel.
        </h1>
        <p class="mx-auto max-w-2xl text-lg text-neutral-500">
          Die technologische Transformation scheitert selten am Mangel an Strategie. Sie scheitert, wenn die Umsetzung vom Leadership abgekoppelt ist. Meine drei Angebote adressieren dieses Problem auf jeder Ebene.
        </p>
      </Col>
      <Col span="2" />
    </Row>
    <!-- Altitude diagram -->
    <Row>
      <Col span="3" />
      <Col span="6" align="center" classes="mt-8">
        <div class="flex flex-col items-center gap-1">
          <div class="flex w-48 items-center justify-center rounded-t-lg bg-secondary-700 px-4 py-3 text-center">
            <div>
              <p class="text-xs font-bold uppercase tracking-widest text-secondary-100">Governance</p>
              <p class="text-sm text-white">Das Was</p>
            </div>
          </div>
          <div class="flex w-64 items-center justify-center bg-secondary-500 px-4 py-3 text-center">
            <div>
              <p class="text-xs font-bold uppercase tracking-widest text-secondary-100">Umsetzung</p>
              <p class="text-sm text-white">Das Wie</p>
            </div>
          </div>
          <div class="flex w-80 items-center justify-center rounded-b-lg bg-secondary-300 px-4 py-3 text-center">
            <div>
              <p class="text-xs font-bold uppercase tracking-widest text-secondary-800">Leadership</p>
              <p class="text-sm text-secondary-700">Das Wer</p>
            </div>
          </div>
        </div>
      </Col>
      <Col span="3" />
    </Row>
  </Section>

  <!-- Three Pillars -->
  <Section padding="both">
    <Row>
      <Col span="12" align="center" classes="mb-12">
        <p class="text-sm font-bold uppercase tracking-widest text-secondary-500">Governance / Umsetzung / Leadership</p>
      </Col>
    </Row>

    <!-- Pillar 1: AI Governance -->
    <Row classes="mb-16">
      <Col span="1" />
      <Col span="5">
        <p class="mb-2 text-sm font-bold uppercase tracking-widest text-secondary-500">Das Was</p>
        <h2 class="mb-4 font-headings text-2xl font-bold text-neutral-900">
          {i18n.services.aiGovernance.name}
        </h2>
        <p class="mb-4 text-neutral-500">
          {i18n.services.aiGovernance.tagline}
        </p>
        <p class="mb-6 text-neutral-600">
          Was sollen wir mit KI tun? Reifegrad-Diagnose auf 7 Achsen, Governance-Framework gemäss ISO 42001, KI-Souveränitätsstrategie, Aktivierungs-Sprint mit integrierter Governance.
        </p>
        <p class="mb-2 text-sm text-neutral-400">Ab CHF 8 500</p>
        <Button type="link" style="primary" variation="link" link="/de/leistungen/ki-governance/">
          Dieses Angebot entdecken &rarr;
        </Button>
      </Col>
      <Col span="5">
        <div class="rounded-lg border border-neutral-100 bg-neutral-50 p-8">
          <Feature icon="heroicons:shield-check" title="Für wen?" align="left">
            <p class="text-sm text-neutral-500">CTO, CISO, Compliance-Verantwortliche, CEO von KMU, die ihre KI-Adoption strukturieren wollen.</p>
          </Feature>
        </div>
      </Col>
      <Col span="1" />
    </Row>

    <!-- Pillar 2: Team Performance -->
    <Row classes="mb-16">
      <Col span="1" />
      <Col span="5">
        <div class="rounded-lg border border-neutral-100 bg-neutral-50 p-8">
          <Feature icon="heroicons:users" title="Für wen?" align="left">
            <p class="text-sm text-neutral-500">CTO, VP Engineering, Head of IT mit Herausforderungen bei Lieferung, Qualität oder Talentbindung.</p>
          </Feature>
        </div>
      </Col>
      <Col span="5">
        <p class="mb-2 text-sm font-bold uppercase tracking-widest text-secondary-500">Das Wie</p>
        <h2 class="mb-4 font-headings text-2xl font-bold text-neutral-900">
          {i18n.services.teamPerformance.name}
        </h2>
        <p class="mb-4 text-neutral-500">
          {i18n.services.teamPerformance.tagline}
        </p>
        <p class="mb-6 text-neutral-600">
          Wie liefern wir wirklich? Flash-Diagnose, eingebettetes Coach & Craft Coaching auf echten Sprints, Specification-Driven Development (SDD), messbare DORA-Metriken ab Monat 3.
        </p>
        <p class="mb-2 text-sm text-neutral-400">Ab CHF 5 500</p>
        <Button type="link" style="primary" variation="link" link="/de/leistungen/team-performance/">
          Dieses Angebot entdecken &rarr;
        </Button>
      </Col>
      <Col span="1" />
    </Row>

    <!-- Pillar 3: Executive Coaching -->
    <Row>
      <Col span="1" />
      <Col span="5">
        <p class="mb-2 text-sm font-bold uppercase tracking-widest text-secondary-500">Das Wer</p>
        <h2 class="mb-4 font-headings text-2xl font-bold text-neutral-900">
          {i18n.services.executiveCoaching.name}
        </h2>
        <p class="mb-4 text-neutral-500">
          {i18n.services.executiveCoaching.tagline}
        </p>
        <p class="mb-6 text-neutral-600">
          Wer hält alles zusammen? Ausgebildet im High-Performance-Coaching (Vantaset, 9 Monate), dann Coach von 100+ Mitarbeitenden. Clarity Session, 6-Monats-Programm, 100-Tage-Beschleuniger.
        </p>
        <p class="mb-2 text-sm text-neutral-400">Ab CHF 1 500</p>
        <Button type="link" style="primary" variation="link" link="/de/leistungen/executive-coaching/">
          Dieses Angebot entdecken &rarr;
        </Button>
      </Col>
      <Col span="5">
        <div class="rounded-lg border border-neutral-100 bg-neutral-50 p-8">
          <Feature icon="heroicons:academic-cap" title="Für wen?" align="left">
            <p class="text-sm text-neutral-500">Technische Führungskräfte in Amt oder Übergang, HR-Leiter auf der Suche nach einem Coach für technische Leader, CEO mit Bedarf an technischem Führungs-Alignment.</p>
          </Feature>
        </div>
      </Col>
      <Col span="1" />
    </Row>
  </Section>

  <!-- Cross-selling -->
  <Section padding="both">
    <Row>
      <Col span="1" />
      <Col span="10">
        <div class="rounded-xl bg-secondary-600 px-8 py-12 text-center">
          <h2 class="mb-6 font-headings text-2xl font-bold text-white">Ein Kunde, drei Zugänge</h2>
          <p class="mx-auto mb-8 max-w-xl text-secondary-100">
            Die drei Angebote sind miteinander verbunden. Eine KI-Diagnose zeigt, dass das Team die identifizierten Use Cases nicht umsetzen kann. Das Team-Coaching zeigt, dass der CTO der Engpass ist. Das CTO-Coaching zeigt, dass der Verwaltungsrat eine strukturierte KI-Strategie erwartet. Jede Tür führt zu den anderen - und der ideale Kunde berührt alle drei über 12-18 Monate.
          </p>
          <Button type="link" size="lg" style="white" variation="outline" link="/de/kontakt/">
            {i18n.cta.primary}
          </Button>
        </div>
      </Col>
      <Col span="1" />
    </Row>
  </Section>

</BaseLayout>
