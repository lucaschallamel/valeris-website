---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Section from '../../../components/ui/Section.astro';
import Row from '../../../components/ui/Row.astro';
import Col from '../../../components/ui/Col.astro';
import Button from '../../../components/ui/Button.astro';
import Feature from '../../../components/ui/Feature.astro';
import List from '../../../components/ui/List.astro';
import { t } from '../../../i18n';

const i18n = t('de');
import CtaBanner from '../../../components/CtaBanner.astro';
---

<BaseLayout title={`${i18n.services.teamPerformance.name} - ${i18n.site.title}`}>

  <!-- Hero -->
  <Section padding="both" classes="bg-neutral-50">
    <Row>
      <Col span="2" />
      <Col span="8" align="center">
        <p class="mb-4 text-sm font-bold uppercase tracking-widest text-secondary-500">Umsetzung</p>
        <h1 class="mb-4 font-headings text-4xl font-black tracking-tight text-neutral-900 lg:text-5xl">
          {i18n.services.teamPerformance.name}
        </h1>
        <p class="mx-auto max-w-2xl text-lg text-neutral-500">
          {i18n.services.teamPerformance.tagline}
        </p>
      </Col>
      <Col span="2" />
    </Row>
  </Section>

  <!-- Das Problem -->
  <Section padding="both">
    <Row>
      <Col span="2" />
      <Col span="8">
        <h2 class="mb-6 font-headings text-2xl font-bold text-neutral-900">Das Problem, das Sie kennen</h2>
        <div class="space-y-4 text-neutral-600">
          <p>Ihre Sprints enden mit unerledigten Stories. Die Time-to-Market verlängert sich. Produktionsvorfälle nehmen zu. Die besten Entwickler beginnen zu gehen.</p>
          <p>Sie haben versucht, Tools hinzuzufügen, Frameworks zu wechseln, mehr zu rekrutieren. Aber das Problem ist nicht technisch - es ist organisatorisch. Die Art, wie Ihr Team arbeitet, kommuniziert und Entscheidungen trifft, ist der eigentliche Hebel.</p>
          <p>Es ist kein Problem individueller Kompetenzen. Es ist ein Systemproblem.</p>
        </div>
      </Col>
      <Col span="2" />
    </Row>
  </Section>

  <!-- Der Ansatz -->
  <Section padding="both" classes="bg-neutral-50">
    <Row>
      <Col span="2" />
      <Col span="8">
        <h2 class="mb-6 font-headings text-2xl font-bold text-neutral-900">Mein Ansatz</h2>
        <p class="mb-8 text-neutral-600">
          Ich messe, bevor ich handle. Mein Ansatz stützt sich auf DORA-Metriken, Prozessbeobachtung und Einzelgespräche, um eine faktenbasierte Diagnose zu erstellen - keine Meinungen.
        </p>
        <div class="grid gap-8 md:grid-cols-2">
          <Feature icon="heroicons:chart-bar" title="Health Check" type="side-icon" iconStyle="square" align="left">
            <p class="text-sm text-neutral-500">Interviews, DORA-Metriken, Prozessbeobachtung, Branchen-Benchmarking.</p>
          </Feature>
          <Feature icon="heroicons:bolt" title="Delivery-Beschleunigung" type="side-icon" iconStyle="square" align="left">
            <p class="text-sm text-neutral-500">3 Monate eingebettetes Coaching, Prozess-Redesign, Einführung von Metriken.</p>
          </Feature>
          <Feature icon="heroicons:light-bulb" title="Kultur-Workshops" type="side-icon" iconStyle="square" align="left">
            <p class="text-sm text-neutral-500">3 halbe Tage zu einem spezifischen Thema (Code Review, Incident Management, etc.), Befragung vorher/nachher.</p>
          </Feature>
          <Feature icon="heroicons:map" title="Leadership Offsite" type="side-icon" iconStyle="square" align="left">
            <p class="text-sm text-neutral-500">Ganztägige Moderation für das technische Führungsteam. Vision, Prioritäten, Alignment.</p>
          </Feature>
        </div>
      </Col>
      <Col span="2" />
    </Row>
  </Section>

  <!-- Pakete -->
  <Section padding="both">
    <Row>
      <Col span="2" />
      <Col span="8">
        <h2 class="mb-8 font-headings text-2xl font-bold text-neutral-900">Engagement-Formate</h2>
        <div class="grid gap-6 md:grid-cols-2">
          <div class="rounded-lg border-2 border-secondary-200 bg-secondary-50/30 p-6">
            <p class="mb-1 text-xs font-bold uppercase tracking-widest text-secondary-500">Einstiegspunkt</p>
            <h3 class="mb-2 font-headings text-xl font-bold text-neutral-900">Engineering Health Check</h3>
            <p class="mb-4 text-sm text-neutral-500">Eine faktenbasierte Diagnose, die dem CTO die Argumente für Investitionen in die Verbesserung liefert.</p>
            <List type="checklist" listItems={[
              { listItem: "5-6 Tage" },
              { listItem: "Lieferobjekt: Bericht + Benchmarks + Empfehlungen" },
              { listItem: "Ab CHF 9 000" },
            ]} />
          </div>
          <div class="rounded-lg border border-neutral-200 p-6">
            <p class="mb-1 text-xs font-bold uppercase tracking-widest text-neutral-400">Vollständiger Weg</p>
            <h3 class="mb-2 font-headings text-xl font-bold text-neutral-900">Delivery-Transformation</h3>
            <p class="mb-4 text-sm text-neutral-500">Health Check, dann 3-monatige Beschleunigung, Kultur-Workshops, jährliches Offsite.</p>
            <List type="checklist" listItems={[
              { listItem: "12 Monate" },
              { listItem: "CHF 40 000 - 50 000 im ersten Jahr" },
              { listItem: "Messbare DORA-Metriken ab Monat 3" },
            ]} />
          </div>
        </div>
      </Col>
      <Col span="2" />
    </Row>
  </Section>

  <!-- Für wen -->
  <Section padding="both" classes="bg-neutral-50">
    <Row>
      <Col span="2" />
      <Col span="8">
        <h2 class="mb-6 font-headings text-2xl font-bold text-neutral-900">Für wen</h2>
        <div class="grid gap-6 md:grid-cols-2">
          <div>
            <h3 class="mb-2 font-headings text-lg font-bold text-neutral-900">CTO / VP Engineering</h3>
            <p class="text-sm text-neutral-500">Die wissen, dass ihr Team besser kann, aber die konkreten Hebel nicht identifizieren können.</p>
          </div>
          <div>
            <h3 class="mb-2 font-headings text-lg font-bold text-neutral-900">Head of IT / CIO</h3>
            <p class="text-sm text-neutral-500">Die mit wiederkehrenden Lieferproblemen konfrontiert sind und einen objektiven externen Blick suchen.</p>
          </div>
          <div>
            <h3 class="mb-2 font-headings text-lg font-bold text-neutral-900">Scale-ups im Wachstum</h3>
            <p class="text-sm text-neutral-500">Deren handwerkliche Prozesse bei Skalierung nicht mehr tragen und die ihr Engineering professionalisieren müssen.</p>
          </div>
          <div>
            <h3 class="mb-2 font-headings text-lg font-bold text-neutral-900">Post-Akquisition / Fusion</h3>
            <p class="text-sm text-neutral-500">Die technische Teams aus unterschiedlichen Kulturen zusammenführen müssen.</p>
          </div>
        </div>
      </Col>
      <Col span="2" />
    </Row>
  </Section>

  <!-- CTA -->
  <CtaBanner lang="de" />

</BaseLayout>
