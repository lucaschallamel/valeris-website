---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/ui/Section.astro';
import Row from '../../components/ui/Row.astro';
import Col from '../../components/ui/Col.astro';
import Button from '../../components/ui/Button.astro';
import Feature from '../../components/ui/Feature.astro';
import { t } from '../../i18n';

const i18n = t('de');
---

<BaseLayout title={`${i18n.about.title} - ${i18n.site.title}`}>

  <!-- Hero -->
  <Section padding="both" classes="bg-neutral-50">
    <Row>
      <Col span="2" />
      <Col span="8" align="center">
        <h1 class="mb-4 font-headings text-4xl font-black tracking-tight text-neutral-900 lg:text-5xl">
          Lucas Challamel
        </h1>
        <p class="mx-auto max-w-2xl text-lg text-neutral-500">
          Gründer, Valeris Coaching. Technischer Direktor, Lösungsarchitekt, Executive Coach. Ansässig in Genf.
        </p>
      </Col>
      <Col span="2" />
    </Row>
  </Section>

  <!-- Portrait + Narrative -->
  <Section padding="both">
    <Row>
      <Col span="1" />
      <Col span="5">
        <!-- TODO: Durch professionelles Foto ersetzen -->
        <div class="flex h-80 items-center justify-center rounded-lg bg-neutral-100">
          <p class="text-neutral-400">[Professionelles Foto]</p>
        </div>
      </Col>
      <Col span="5">
        <h2 class="mb-4 font-headings text-2xl font-bold text-neutral-900">Der Werdegang</h2>
        <div class="space-y-4 text-neutral-600">
          <p>
            Mehr als 15 Jahre im technologischen Leadership, von Frankreich über Australien bis in die Schweiz. Ich habe technische Teams auf jeder Stufe aufgebaut, geleitet und gesteuert - vom Startup bis zur internationalen Beratungsfirma.
          </p>
          <p>
            Als Technischer Direktor bei Talan SA habe ich digitale Transformationsprogramme für Schweizer Unternehmen in den Bereichen Finanzen, Pharma und öffentlicher Sektor geleitet. Ich habe Lösungsarchitekturen entworfen, KI-Governance-Frameworks aufgebaut und technische Führungsteams gecoacht.
          </p>
          <p>
            Was mich unterscheidet: Ich habe jede der Rollen ausgeübt, für die ich heute berate. Ich habe kein Buch über das CTO-Dasein gelesen - ich habe die durchwachten Nächte, die unmöglichen Entscheidungen und die erfolgreichen Transformationen erlebt.
          </p>
        </div>
      </Col>
      <Col span="1" />
    </Row>
  </Section>

  <!-- Credentials -->
  <Section padding="both" classes="bg-neutral-50">
    <Row>
      <Col span="2" />
      <Col span="8">
        <h2 class="mb-8 font-headings text-2xl font-bold text-neutral-900 text-center">Expertise und Referenzen</h2>
        <div class="grid gap-8 md:grid-cols-3">
          <Feature icon="heroicons:building-office" title="Erfahrung" align="center">
            <p class="text-sm text-neutral-500">
              15+ Jahre in technischer Führung. Ex-Technischer Direktor, Talan SA. Frankreich, Australien, Schweiz.
            </p>
          </Feature>
          <Feature icon="heroicons:academic-cap" title="Zertifizierungen" align="center">
            <p class="text-sm text-neutral-500">
              ISO 42001 (in Vorbereitung). Expertise AI/ML, Cloud, IT-Governance. TOGAF (geplant).
            </p>
          </Feature>
          <Feature icon="heroicons:globe-europe-africa" title="Kontext" align="center">
            <p class="text-sm text-neutral-500">
              Ansässig in Genf. Zweisprachig Französisch/Englisch. Tätig in der Westschweiz und international.
            </p>
          </Feature>
        </div>
      </Col>
      <Col span="2" />
    </Row>
  </Section>

  <!-- Methodology -->
  <Section padding="both">
    <Row>
      <Col span="2" />
      <Col span="8">
        <h2 class="mb-6 font-headings text-2xl font-bold text-neutral-900">{i18n.about.methodology}</h2>
        <p class="mb-8 text-neutral-600">
          Jedes Engagement beginnt mit einer strukturierten Diagnose. Keine generischen Templates. Keine vorgefertigten Frameworks. Lösungen, die für Ihren spezifischen Kontext konzipiert sind.
        </p>
        <div class="grid gap-8 md:grid-cols-3">
          <div class="text-center">
            <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-secondary-400 text-lg font-bold text-white">1</div>
            <h3 class="mb-2 font-headings text-lg font-bold text-neutral-900">Diagnose</h3>
            <p class="text-sm text-neutral-500">Ihre Situation, Ihre Einschränkungen, Ihre Ziele verstehen. Messen, bevor man handelt.</p>
          </div>
          <div class="text-center">
            <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-secondary-400 text-lg font-bold text-white">2</div>
            <h3 class="mb-2 font-headings text-lg font-bold text-neutral-900">Rahmen</h3>
            <p class="text-sm text-neutral-500">Gemeinsam den Umfang, die messbaren Ziele und den Aktionsplan definieren.</p>
          </div>
          <div class="text-center">
            <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-secondary-400 text-lg font-bold text-white">3</div>
            <h3 class="mb-2 font-headings text-lg font-bold text-neutral-900">Begleitung</h3>
            <p class="text-sm text-neutral-500">Umsetzen, messen, anpassen. Wissenstransfer, damit Sie autonom werden.</p>
          </div>
        </div>
      </Col>
      <Col span="2" />
    </Row>
  </Section>

  <!-- Values -->
  <Section padding="both" classes="bg-neutral-50">
    <Row>
      <Col span="2" />
      <Col span="8">
        <h2 class="mb-6 font-headings text-2xl font-bold text-neutral-900">Wie ich arbeite</h2>
        <div class="space-y-6">
          <div class="flex gap-4">
            <div class="shrink-0 text-2xl text-primary-500">&bull;</div>
            <div>
              <h3 class="mb-1 font-headings text-lg font-bold text-neutral-900">Direkt mit Ihnen</h3>
              <p class="text-neutral-500">Keine Junioren, keine Subunternehmer. Sie arbeiten direkt mit mir. Die Seltenheit des Gesprächspartners ist Teil des Wertes.</p>
            </div>
          </div>
          <div class="flex gap-4">
            <div class="shrink-0 text-2xl text-primary-500">&bull;</div>
            <div>
              <h3 class="mb-1 font-headings text-lg font-bold text-neutral-900">Radikale Ehrlichkeit</h3>
              <p class="text-neutral-500">Ich sage Nein zu Engagements, bei denen ich keinen echten Mehrwert liefern kann. Ich bevorzuge eine Vertrauensbeziehung gegenüber einem zusätzlichen Vertrag.</p>
            </div>
          </div>
          <div class="flex gap-4">
            <div class="shrink-0 text-2xl text-primary-500">&bull;</div>
            <div>
              <h3 class="mb-1 font-headings text-lg font-bold text-neutral-900">Wissenstransfer</h3>
              <p class="text-neutral-500">Das Ziel ist Ihre Autonomie, nicht Ihre Abhängigkeit. Ich arbeite mit Führungskräften, nicht für sie.</p>
            </div>
          </div>
        </div>
      </Col>
      <Col span="2" />
    </Row>
  </Section>

  <!-- CTA -->
  <Section padding="both">
    <Row>
      <Col span="1" />
      <Col span="10">
        <div class="rounded-xl bg-secondary-600 px-8 py-12 text-center">
          <h2 class="mb-4 font-headings text-2xl font-bold text-white">Bereit zum Gespräch?</h2>
          <p class="mx-auto mb-6 max-w-xl text-secondary-100">
            Ein 30-minütiges Gespräch, kein Verkaufspitch.
          </p>
          <div class="flex flex-wrap justify-center gap-4">
            <Button type="link" size="lg" style="white" variation="outline" link="/de/kontakt/">
              {i18n.cta.primary}
            </Button>
            <Button type="link" size="lg" style="white" variation="outline" link="https://linkedin.com/in/lucaschallamel">
              LinkedIn
            </Button>
          </div>
        </div>
      </Col>
      <Col span="1" />
    </Row>
  </Section>

</BaseLayout>
