---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/ui/Section.astro';
import Row from '../../components/ui/Row.astro';
import Col from '../../components/ui/Col.astro';
import Button from '../../components/ui/Button.astro';
import Feature from '../../components/ui/Feature.astro';
import { Image } from 'astro:assets';
import { t } from '../../i18n';
import wpCover from '../../assets/wp_ai_sovereignty_ch.webp';

const i18n = t('de');
import CtaBanner from '../../components/CtaBanner.astro';
---

<BaseLayout title={`${i18n.nav.publications} - ${i18n.site.title}`} description={i18n.site.descriptions.publications}>

  <!-- Hero -->
  <Section padding="both" classes="bg-neutral-50">
    <Row>
      <Col span="2" />
      <Col span="8" align="center">
        <h1 class="mb-4 font-headings text-4xl font-black tracking-tight text-neutral-900 lg:text-5xl">
          Publikationen
        </h1>
        <p class="mx-auto max-w-2xl text-lg text-neutral-500">
          Whitepaper, Essays und Ressourcen zu technologischem Leadership, KI-Governance und der Transformation von Organisationen.
        </p>
      </Col>
      <Col span="2" />
    </Row>
  </Section>

  <!-- Featured: AI Sovereignty White Paper -->
  <Section padding="both">
    <Row>
      <Col span="1" />
      <Col span="10">
        <div class="rounded-lg border-2 border-primary-100 bg-primary-50/20 p-8 md:p-12">
          <Row>
            <Col span="7">
              <p class="mb-2 text-xs font-bold uppercase tracking-widest text-secondary-500">Whitepaper</p>
              <h2 class="mb-4 font-headings text-3xl font-bold text-neutral-900">
                KI-Souveränität: Praktischer Leitfaden für Schweizer Unternehmen
              </h2>
              <p class="mb-4 text-neutral-600">
                Wie Sie künstliche Intelligenz einsetzen, ohne die Kontrolle über Ihre Daten, Ihre Entscheidungen und Ihre digitale Zukunft abzugeben. Ein pragmatischer Leitfaden für Führungskräfte, die über den Hype hinausgehen wollen.
              </p>
              <p class="mb-6 text-sm text-neutral-500">
                Themen: Datensouveränität, Schweizer (nDSG) und europäischer Rechtsrahmen (EU AI Act), Anbieterbewertung, Modell-Governance, Build vs. Buy, ISO 42001.
              </p>
              <div class="flex flex-wrap gap-2 mb-6">
                <span class="rounded-full bg-neutral-100 px-3 py-1 text-xs font-medium text-neutral-600">KI-Governance</span>
                <span class="rounded-full bg-neutral-100 px-3 py-1 text-xs font-medium text-neutral-600">Digitale Souveränität</span>
                <span class="rounded-full bg-neutral-100 px-3 py-1 text-xs font-medium text-neutral-600">ISO 42001</span>
                <span class="rounded-full bg-neutral-100 px-3 py-1 text-xs font-medium text-neutral-600">nDSG / EU AI Act</span>
              </div>
              <Button type="link" size="lg" style="primary" link="/de/kontakt/" elevated>
                Whitepaper erhalten
              </Button>
              <p class="mt-3 text-xs text-neutral-400">Kostenlos. Versand per E-Mail nach Registrierung.</p>
            </Col>
            <Col span="5">
              <Image
                src={wpCover}
                alt="KI-Souveränität - Whitepaper für Schweizer Unternehmen"
                class="rounded-lg shadow-lg"
                width={500}
                quality={90}
              />
            </Col>
          </Row>
        </div>
      </Col>
      <Col span="1" />
    </Row>
  </Section>

  <!-- Upcoming publications -->
  <Section padding="both" classes="bg-neutral-50">
    <Row>
      <Col span="2" />
      <Col span="8">
        <h2 class="mb-8 font-headings text-2xl font-bold text-neutral-900 text-center">Demnächst</h2>
        <div class="grid gap-6 md:grid-cols-2">

          <!-- Essay 1 -->
          <div class="rounded-lg border border-neutral-200 bg-white p-6">
            <p class="mb-2 text-xs font-bold uppercase tracking-widest text-neutral-400">Essay</p>
            <h3 class="mb-2 font-headings text-xl font-bold text-neutral-900">
              Der CTO im Zeitalter der generativen KI
            </h3>
            <p class="mb-4 text-sm text-neutral-500">
              Wie sich die Rolle des technischen Direktors verändert, wenn KI zum Teammitglied wird. Leadership, Entscheidungsarchitektur und die Frage der bewussten Obsoleszenz.
            </p>
            <div class="flex flex-wrap gap-2">
              <span class="rounded-full bg-neutral-100 px-3 py-1 text-xs font-medium text-neutral-600">Technisches Leadership</span>
              <span class="rounded-full bg-neutral-100 px-3 py-1 text-xs font-medium text-neutral-600">Generative KI</span>
            </div>
          </div>

          <!-- Essay 2 -->
          <div class="rounded-lg border border-neutral-200 bg-white p-6">
            <p class="mb-2 text-xs font-bold uppercase tracking-widest text-neutral-400">Essay</p>
            <h3 class="mb-2 font-headings text-xl font-bold text-neutral-900">
              Messen, was zählt: Jenseits der DORA-Metriken
            </h3>
            <p class="mb-4 text-sm text-neutral-500">
              Performance-Engineering-Metriken sind notwendig, aber nicht ausreichend. Was die Zahlen nicht erfassen - und wie man das Bild vervollständigt.
            </p>
            <div class="flex flex-wrap gap-2">
              <span class="rounded-full bg-neutral-100 px-3 py-1 text-xs font-medium text-neutral-600">Performance Engineering</span>
              <span class="rounded-full bg-neutral-100 px-3 py-1 text-xs font-medium text-neutral-600">Metriken</span>
            </div>
          </div>

        </div>
      </Col>
      <Col span="2" />
    </Row>
  </Section>

  <!-- Newsletter / Blog link -->
  <CtaBanner lang="de" />

</BaseLayout>
