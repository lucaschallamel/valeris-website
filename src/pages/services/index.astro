---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/ui/Section.astro';
import Row from '../../components/ui/Row.astro';
import Col from '../../components/ui/Col.astro';
import Button from '../../components/ui/Button.astro';
import Feature from '../../components/ui/Feature.astro';
import { t } from '../../i18n';

const i18n = t('fr');
import CtaBanner from '../../components/CtaBanner.astro';
---

<BaseLayout title={`${i18n.nav.services} - ${i18n.site.title}`} description={i18n.site.descriptions.services}>

  <!-- Hero -->
  <Section padding="both" classes="bg-neutral-50" abstractBg>
    <Row>
      <Col span="2" />
      <Col span="8" align="center">
        <h1 class="mb-4 font-headings text-4xl font-black tracking-tight text-neutral-900 lg:text-5xl">
          Trois altitudes, un seul objectif.
        </h1>
        <p class="mx-auto max-w-2xl text-lg text-neutral-500">
          La transformation technologique échoue rarement par manque de stratégie. Elle échoue quand l'exécution est déconnectée du leadership. Mes trois offres adressent ce problème à chaque niveau.
        </p>
      </Col>
      <Col span="2" />
    </Row>
    <!-- Altitude diagram -->
    <Row>
      <Col span="3" />
      <Col span="6" align="center" classes="mt-8">
        <div class="flex flex-col items-center gap-1">
          <div class="flex w-48 items-center justify-center rounded-t-lg bg-secondary-700 px-4 py-3 text-center">
            <div>
              <p class="text-xs font-bold uppercase tracking-widest text-secondary-100">Gouvernance</p>
              <p class="text-sm text-white">Le quoi</p>
            </div>
          </div>
          <div class="flex w-64 items-center justify-center bg-secondary-500 px-4 py-3 text-center">
            <div>
              <p class="text-xs font-bold uppercase tracking-widest text-secondary-100">Exécution</p>
              <p class="text-sm text-white">Le comment</p>
            </div>
          </div>
          <div class="flex w-80 items-center justify-center rounded-b-lg bg-secondary-300 px-4 py-3 text-center">
            <div>
              <p class="text-xs font-bold uppercase tracking-widest text-secondary-800">Leadership</p>
              <p class="text-sm text-secondary-700">Le qui</p>
            </div>
          </div>
        </div>
      </Col>
      <Col span="3" />
    </Row>
  </Section>

  <!-- Three Pillars -->
  <Section padding="both">
    <Row>
      <Col span="12" align="center" classes="mb-12">
        <p class="text-sm font-bold uppercase tracking-widest text-secondary-500">Gouvernance / Exécution / Leadership</p>
      </Col>
    </Row>

    <!-- Pillar 1: AI Governance -->
    <Row classes="mb-16">
      <Col span="1" />
      <Col span="5">
        <a href="/services/gouvernance-ia/" class="group block">
          <p class="mb-2 text-sm font-bold uppercase tracking-widest text-secondary-500">Le quoi</p>
          <h2 class="mb-4 font-headings text-2xl font-bold text-neutral-900 group-hover:text-primary-500">
            {i18n.services.aiGovernance.name}
          </h2>
          <p class="mb-4 text-neutral-500">
            {i18n.services.aiGovernance.tagline}
          </p>
          <p class="mb-6 text-neutral-600">
            Que devons-nous faire avec l'IA ? Diagnostic de maturité sur 7 axes, cadre de gouvernance aligné ISO 42001, stratégie de souveraineté IA, sprint d'activation avec gouvernance intégrée.
          </p>
          <p class="mb-2 text-sm text-neutral-400">À partir de CHF 8 500</p>
          <span class="font-bold text-primary-500">Découvrir cette offre &rarr;</span>
        </a>
      </Col>
      <Col span="5">
        <div class="rounded-lg border border-neutral-100 bg-neutral-50 p-8">
          <Feature icon="heroicons:shield-check" title="Pour qui ?" align="left">
            <p class="text-sm text-neutral-500">CTO, CISO, responsables conformité, CEO de PME cherchant à structurer leur adoption de l'IA.</p>
          </Feature>
        </div>
      </Col>
      <Col span="1" />
    </Row>

    <!-- Pillar 2: Team Performance -->
    <Row classes="mb-16">
      <Col span="1" />
      <Col span="5">
        <div class="rounded-lg border border-neutral-100 bg-neutral-50 p-8">
          <Feature icon="heroicons:users" title="Pour qui ?" align="left">
            <p class="text-sm text-neutral-500">CTO, VP Engineering, Head of IT confrontés à des problèmes de livraison, de qualité ou de rétention des talents.</p>
          </Feature>
        </div>
      </Col>
      <Col span="5">
        <a href="/services/performance-equipes/" class="group block">
          <p class="mb-2 text-sm font-bold uppercase tracking-widest text-secondary-500">Le comment</p>
          <h2 class="mb-4 font-headings text-2xl font-bold text-neutral-900 group-hover:text-primary-500">
            {i18n.services.teamPerformance.name}
          </h2>
          <p class="mb-4 text-neutral-500">
            {i18n.services.teamPerformance.tagline}
          </p>
          <p class="mb-6 text-neutral-600">
            Comment livrons-nous réellement ? Diagnostic flash, coaching embarqué Coach & Craft sur des sprints réels, Specification-Driven Development, métriques DORA mesurables dès le mois 3.
          </p>
          <p class="mb-2 text-sm text-neutral-400">À partir de CHF 5 500</p>
          <span class="font-bold text-primary-500">Découvrir cette offre &rarr;</span>
        </a>
      </Col>
      <Col span="1" />
    </Row>

    <!-- Pillar 3: Executive Coaching -->
    <Row>
      <Col span="1" />
      <Col span="5">
        <a href="/services/coaching-executif/" class="group block">
          <p class="mb-2 text-sm font-bold uppercase tracking-widest text-secondary-500">Le qui</p>
          <h2 class="mb-4 font-headings text-2xl font-bold text-neutral-900 group-hover:text-primary-500">
            {i18n.services.executiveCoaching.name}
          </h2>
          <p class="mb-4 text-neutral-500">
            {i18n.services.executiveCoaching.tagline}
          </p>
          <p class="mb-6 text-neutral-600">
            Qui tient tout ensemble ? Formé au coaching de haute performance (Vantaset, 9 mois), puis coach de 100+ collaborateurs. Session de clarté, programme 6 mois, accélérateur 100 jours.
          </p>
          <p class="mb-2 text-sm text-neutral-400">À partir de CHF 1 500</p>
          <span class="font-bold text-primary-500">Découvrir cette offre &rarr;</span>
        </a>
      </Col>
      <Col span="5">
        <div class="rounded-lg border border-neutral-100 bg-neutral-50 p-8">
          <Feature icon="heroicons:academic-cap" title="Pour qui ?" align="left">
            <p class="text-sm text-neutral-500">Dirigeants techniques en poste ou en transition, DRH cherchant un coach pour un leader technique, CEO voulant aligner sa direction technique.</p>
          </Feature>
        </div>
      </Col>
      <Col span="1" />
    </Row>
  </Section>

  <!-- Cross-selling -->
  <CtaBanner lang="fr" />

</BaseLayout>
