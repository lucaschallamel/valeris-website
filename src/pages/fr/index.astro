---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t } from '../../i18n';

const i18n = t('fr');
---

<BaseLayout title={`${i18n.site.title} - ${i18n.hero.headline}`}>
  <section class="hero">
    <h1>{i18n.hero.headline}</h1>
    <p class="subheadline">{i18n.hero.subheadline}</p>
    <a href="/fr/contact/" class="cta-primary">{i18n.cta.primary}</a>
  </section>

  <section class="services-preview">
    <div class="service-card">
      <h3>{i18n.services.aiGovernance.name}</h3>
      <p>{i18n.services.aiGovernance.tagline}</p>
      <a href="/fr/services/gouvernance-ia/">{i18n.cta.secondary}</a>
    </div>
    <div class="service-card">
      <h3>{i18n.services.teamPerformance.name}</h3>
      <p>{i18n.services.teamPerformance.tagline}</p>
      <a href="/fr/services/performance-equipes/">{i18n.cta.secondary}</a>
    </div>
    <div class="service-card">
      <h3>{i18n.services.executiveCoaching.name}</h3>
      <p>{i18n.services.executiveCoaching.tagline}</p>
      <a href="/fr/services/coaching-executif/">{i18n.cta.secondary}</a>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    text-align: center;
    padding: 4rem 0;
  }

  .hero h1 {
    font-family: var(--font-serif);
    font-size: 3rem;
    color: var(--color-primary);
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
  }

  .subheadline {
    font-size: 1.25rem;
    color: #555;
    max-width: 40rem;
    margin: 0 auto 2rem;
  }

  .cta-primary {
    display: inline-block;
    padding: 0.75rem 2rem;
    background: var(--color-accent);
    color: white;
    text-decoration: none;
    border-radius: 0.375rem;
    font-weight: 500;
  }

  .services-preview {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(18rem, 1fr));
    gap: 2rem;
    padding: 2rem 0;
  }

  .service-card {
    padding: 2rem;
    border: 1px solid #e5e5e3;
    border-radius: 0.5rem;
  }

  .service-card h3 {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    color: var(--color-primary);
    margin-top: 0;
  }

  .service-card p {
    color: #555;
    font-size: 0.95rem;
  }

  .service-card a {
    color: var(--color-accent);
    text-decoration: none;
    font-weight: 500;
  }
</style>
