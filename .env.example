# Valeris Website - Environment Variables
#
# For LOCAL development: copy this file to .env and fill in values
# For PRODUCTION: use wrangler to set secrets:
#   npx wrangler pages secret put <NAME> --project-name valeris-website
#
# See docs-valeris/operations/deployment-guide.md for details

# ------------------------------------------------------------------
# Site
# ------------------------------------------------------------------
PUBLIC_SITE_URL=https://valeris.fr

# ------------------------------------------------------------------
# Resend - Email delivery (contact form)
# Dashboard: https://resend.com/api-keys
# Permission: Sending access only
# Domain: valeris.fr (verified)
# ------------------------------------------------------------------
RESEND_API_KEY=re_xxxxxxxxxxxx

# ------------------------------------------------------------------
# Cloudflare Turnstile - Captcha (contact form)
# Dashboard: dash.cloudflare.com > Application security > Turnstile
# Site Key (public, in HTML): 0x4AAAAAACw1vy6U50c8ODeg
# Secret Key (private, below):
# ------------------------------------------------------------------
TURNSTILE_SECRET_KEY=0x4AAAAAAA_xxxxxxxxxxxxxxxx

# ------------------------------------------------------------------
# Contact form - destination email
# ------------------------------------------------------------------
CONTACT_EMAIL=your@email.com

# ------------------------------------------------------------------
# Analytics (optional, not yet configured)
# ------------------------------------------------------------------
# PUBLIC_PLAUSIBLE_DOMAIN=valeris.fr
# PUBLIC_PLAUSIBLE_URL=https://plausible.io
